---
import AuthLayout from '../../layouts/AuthLayout.astro';
import { langStaticPaths } from '../../i18n/page';

export const getStaticPaths = langStaticPaths;

const { lang, t } = Astro.locals;
---

<AuthLayout
  title={t('forgot:page-title')}
  description={t('meta:forgot-description')}
  heading={t('forgot:heading')}
  intro={t('forgot:intro')}
  action="https://client.sinclair.bio/forgot-password"
  submitLabel={t('forgot:submit')}
>
  <div class="field">
    <label for="email">{t('forgot:email-label')}</label>
    <input
      id="email"
      name="email"
      type="email"
      autocomplete="username"
      placeholder={t('forgot:email-placeholder')}
      required
    />
  </div>

  <a slot="footer" href={`/${lang}/login`}>{t('forgot:back-to-login')}</a>
</AuthLayout>
