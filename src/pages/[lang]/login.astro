---
import Layout from '../../layouts/Layout.astro';
import { Languages } from '../../i18n/translations';

export function getStaticPaths() {
  return Object.values(Languages).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Languages;
---

<Layout lang={lang} title="Sinclair | Login">
  <section class="login-page">
    <div class="login-shell">
      <header class="login-header">
        <h1>Lorem ipsum</h1>
        <p>Dolor sit amet, consectetur adipiscing elit sed do eiusmod.</p>
      </header>

      <form class="login-form">
        <div class="field">
          <label for="email">Consectetur</label>
          <input id="email" type="email" placeholder="adipiscing@elit.com" disabled />
        </div>
        <div class="field">
          <label for="password">Adipiscing elit</label>
          <input id="password" type="password" placeholder="••••••••••••" disabled />
        </div>

        <div class="form-options">
          <label class="checkbox-label">
            <input type="checkbox" disabled />
            Lorem ipsum dolor
          </label>
          <a href="#" class="forgot-link">Consectetur adipiscing?</a>
        </div>

        <div class="placeholder-notice">
          <span>⚠</span> Lorem ipsum dolor sit amet — this form is not yet active.
        </div>

        <button type="button" disabled>Lorem ipsum</button>

        <p class="divider"><span>— Lorem ipsum —</span></p>

        <div class="oauth-buttons">
          <button type="button" class="oauth-btn" disabled>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Lorem ipsum
          </button>
          <button type="button" class="oauth-btn" disabled>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            Dolor sit amet
          </button>
        </div>
      </form>

      <p class="signup-link">Lorem ipsum dolor? <a href="#">Consectetur adipiscing</a></p>
    </div>
  </section>
</Layout>

<style>
  .login-page {
    min-height: calc(100vh - 4rem);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-back);
    padding: 2rem 1.25rem;
    animation: reveal 400ms ease-out both;
  }

  .login-shell {
    width: min(420px, 100%);
  }

  .login-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }

  .login-header p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-surface);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }

  input[type="email"],
  input[type="password"] {
    padding: 0.6rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-back);
    color: var(--color-ink);
    font-size: 0.95rem;
    font-family: inherit;
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-options {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.85rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-muted);
    cursor: not-allowed;
    opacity: 0.6;
  }

  .forgot-link {
    color: var(--color-accent);
    text-decoration: none;
    opacity: 0.5;
    pointer-events: none;
  }

  .placeholder-notice {
    padding: 0.65rem 0.85rem;
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    color: var(--color-muted);
    font-size: 0.8rem;
  }

  button {
    width: 100%;
    padding: 0.7rem;
    border-radius: 0.5rem;
    border: none;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    font-family: inherit;
    opacity: 0.4;
    cursor: not-allowed;
  }

  .divider {
    margin: 0;
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-muted);
    opacity: 0.6;
  }

  .oauth-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .oauth-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    background: var(--color-back);
    border: 1px solid var(--color-border) !important;
    color: var(--color-ink);
    font-size: 0.9rem;
  }

  .signup-link {
    margin: 1.25rem 0 0;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .signup-link a {
    color: var(--color-accent);
    text-decoration: none;
    opacity: 0.5;
    pointer-events: none;
  }

  @keyframes reveal {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
