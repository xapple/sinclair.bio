---
import AuthLayout from '../../layouts/AuthLayout.astro';
import { langStaticPaths, usePage } from '../../i18n/page';

export const getStaticPaths = langStaticPaths;

const { lang, t } = usePage(Astro.params);
---

<AuthLayout
  title={t('login:page-title')}
  description={t('meta:login-description')}
  heading={t('login:heading')}
  intro={t('login:intro')}
  action="https://client.sinclair.bio/login"
  submitLabel={t('login:submit')}
>
  <div class="field">
    <label for="email">{t('login:email-label')}</label>
    <input
      id="email"
      name="email"
      type="email"
      autocomplete="username"
      placeholder={t('login:email-placeholder')}
      required
    />
  </div>
  <div class="field">
    <label for="password">{t('login:password-label')}</label>
    <input
      id="password"
      name="password"
      type="password"
      autocomplete="current-password"
      placeholder={t('login:password-placeholder')}
      required
    />
  </div>

  <div class="form-options">
    <label class="checkbox-label">
      <input type="checkbox" name="remember" value="true" />
      {t('login:remember')}
    </label>
    <a href={`/${lang}/forgot-password`} class="forgot-link">{t('login:forgot')}</a>
  </div>

  <Fragment slot="footer">{t('login:client-only')}</Fragment>
</AuthLayout>
