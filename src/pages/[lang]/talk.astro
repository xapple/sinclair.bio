---
import LangPage from '../../layouts/LangPage.astro';
import { langStaticPaths, usePage } from '../../i18n/page';

export const getStaticPaths = langStaticPaths;

const { t } = usePage(Astro.params);
---

<LangPage
  title={t('talk:page-title')}
  description={t('meta:talk-description')}
  shellWidth="960px"
>
  <div class="talk-reveal talk-page">
    <header class="talk-header">
      <h1>{t('talk:heading')}</h1>
      <p class="subtitle">{t('talk:intro')}</p>
    </header>

    <div id="cal-inline" class="cal-inline"></div>
  </div>
</LangPage>

<script>
  import { mountCalEmbed, watchThemeAndRemount } from '../../scripts/cal-embed';

  const options = {
    calLink: 'sinclair.bio',
    namespace: '30min',
    origin: 'https://app.cal.eu',
    embedSrc: 'https://app.cal.eu/embed/embed.js',
  };

  mountCalEmbed(options);
  watchThemeAndRemount(options);
</script>

<!-- Lock the outer page to the viewport on the Talk page so the Cal embed
     owns the only scroll context. Otherwise Cal's slot view (sticky date
     header + scrollable slot list) and the outer page both scroll, which
     fights touch/wheel events on small viewports. -->
<style is:global>
  html:has(.talk-page),
  html:has(.talk-page) body {
    height: 100dvh;
    overflow: hidden;
  }
  html:has(.talk-page) .page-frame {
    min-height: 0;
    height: calc(100dvh - 4rem); /* topbar is h-16 */
    padding-block: clamp(0.75rem, 2.5vw, 1.75rem);
    display: flex;
    flex-direction: column;
  }
  html:has(.talk-page) .page-shell {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
</style>

<style>
  .talk-reveal {
    animation: reveal 400ms ease-out both;
  }

  .talk-page {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  .talk-header {
    margin-bottom: clamp(0.75rem, 2vw, 1.25rem);
    flex: 0 0 auto;
  }

  h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.4rem, 2.6vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }

  .subtitle {
    margin: 0;
    max-width: 60ch;
    color: var(--color-muted);
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    line-height: 1.5;
  }

  .cal-inline {
    flex: 1;
    min-height: 0;
    width: 100%;
    border-radius: 0.75rem;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  /* Make Cal's injected iframe fill the wrapper exactly so its internal
     scroll lives inside this box, not the outer page. */
  .cal-inline :global(iframe) {
    width: 100% !important;
    height: 100% !important;
    border: 0;
    display: block;
  }
</style>
