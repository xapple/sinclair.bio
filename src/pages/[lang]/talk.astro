---
import Layout from '../../layouts/Layout.astro';
import Reveal from '../../components/Reveal.astro';
import { langStaticPaths } from '../../i18n/page';

export const getStaticPaths = langStaticPaths;

const { t } = Astro.locals;
---

<Layout
  title={t('talk:page-title')}
  description={t('meta:talk-description')}
  shellWidth="960px"
>
  <Reveal duration={400}>
    <header class="talk-header">
      <h1>{t('talk:heading')}</h1>
      <p class="subtitle">{t('talk:intro')}</p>
    </header>

    <div id="cal-inline" class="cal-inline"></div>

    <p class="embed-notice">* {t('talk:embed-notice')}</p>
  </Reveal>
</Layout>

<script>
  import { mountCalEmbed, watchThemeAndRestyle, type CalEmbedOptions } from '../../scripts/cal-embed';
  import { THEME_ACCENT } from '../../scripts/theme-switcher';

  const options: CalEmbedOptions = {
    calLink: 'sinclair.bio',
    namespace: '30min',
    origin: 'https://app.cal.eu',
    embedSrc: 'https://app.cal.eu/embed/embed.js',
    brandColors: THEME_ACCENT,
  };

  mountCalEmbed(options);
  watchThemeAndRestyle(options);
</script>

<style>
  .talk-header {
    margin-bottom: clamp(1.75rem, 3.5vw, 2.5rem);
  }

  h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }

  .subtitle {
    margin: 0;
    max-width: 60ch;
    color: var(--color-muted);
    font-size: clamp(0.95rem, 1.2vw, 1.05rem);
    line-height: 1.6;
  }

  .cal-inline {
    width: 100%;
    min-height: 640px;
    border-radius: 0.75rem;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .embed-notice {
    margin: 0.85rem 0 0;
    color: var(--color-muted);
    font-size: 0.75rem;
    line-height: 1.5;
    opacity: 0.8;
    text-align: center;
  }
</style>
