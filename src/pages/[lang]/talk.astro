---
import LangPage from '../../layouts/LangPage.astro';
import { Languages, useTranslations } from '../../i18n/translations';
import { langStaticPaths } from '../../i18n/page';

export const getStaticPaths = langStaticPaths;

const lang = Astro.params.lang as Languages;
const t = useTranslations(lang);

// Cal.com inline embed configuration.
const CAL_LINK = 'sinclair.bio';
const CAL_NAMESPACE = '30min';
const CAL_ORIGIN = 'https://app.cal.eu';
const CAL_EMBED_SRC = 'https://app.cal.eu/embed/embed.js';
---

<LangPage
  lang={lang}
  title={t('talk:page-title')}
  description={t('meta:talk-description')}
  shellWidth="960px"
>
  <div class="talk-reveal">
    <header class="talk-header">
      <h1>{t('talk:heading')}</h1>
      <p class="subtitle">{t('talk:intro')}</p>
    </header>

    <div
      id="cal-inline"
      class="cal-inline"
      data-cal-link={CAL_LINK}
      data-cal-namespace={CAL_NAMESPACE}
      data-cal-origin={CAL_ORIGIN}
      data-cal-embed-src={CAL_EMBED_SRC}
    ></div>
  </div>
</LangPage>

<script>
  // Cal.com inline embed — re-initialised on every Astro view-transition load.
  function getCalTheme(): 'dark' | 'light' {
    return document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
  }

  function initCalEmbed() {
    const el = document.getElementById('cal-inline');
    if (!el) return;

    const calLink = el.dataset.calLink;
    const namespace = el.dataset.calNamespace;
    const origin = el.dataset.calOrigin || 'https://cal.com';
    const embedSrc = el.dataset.calEmbedSrc || 'https://app.cal.com/embed/embed.js';
    if (!calLink || !namespace) return;

    // Official Cal.com embed bootstrap (loads embed.js once, queues calls).
    (function (C: any, A: string, L: string) {
      let p = function (a: any, ar: any) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement('script')).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api: any = function () { p(api, arguments); };
          const ns = ar[1];
          api.q = api.q || [];
          if (typeof ns === 'string') {
            cal.ns[ns] = cal.ns[ns] || api;
            p(cal.ns[ns], ar);
            p(cal, ['initNamespace', ns]);
          } else {
            p(cal, ar);
          }
          return;
        }
        p(cal, ar);
      };
    })(window, embedSrc, 'init');

    const Cal = (window as any).Cal;
    const theme = getCalTheme();

    Cal('init', namespace, { origin });

    // Clear any previous render (SPA re-mount).
    el.innerHTML = '';

    Cal.ns[namespace]('inline', {
      elementOrSelector: '#cal-inline',
      config: { layout: 'month_view', theme, useSlotsViewOnSmallScreen: true },
      calLink,
    });

    Cal.ns[namespace]('ui', {
      hideEventTypeDetails: false,
      layout: 'month_view',
      theme,
      cssVarsPerTheme: {
        light: { 'cal-brand': '#6b2c2c' },
        dark: { 'cal-brand': '#b85252' },
      },
    });

    // Mirror Cal's reported content height onto the wrapper so the embed grows
    // with internal navigation (date picker → time slots → confirmation) instead
    // of scrolling inside the iframe on small viewports.
    Cal.ns[namespace]('on', {
      action: '__dimensionChanged',
      callback: (e: any) => {
        const h = e?.detail?.data?.iframeHeight;
        if (typeof h === 'number' && h > 0) {
          el.style.minHeight = `${h}px`;
        }
      },
    });
  }

  // Re-mount Cal embed when the user toggles the site theme — the iframe
  // bakes the theme into its URL, so a soft `ui` update doesn't re-theme it.
  function watchThemeChanges() {
    const state = ((window as any).__calInlineEmbedState ??= {
      lastTheme: null,
      observer: null,
    });
    if (state.observer) return;

    const html = document.documentElement;
    state.lastTheme = getCalTheme();
    const observer = new MutationObserver(() => {
      const theme = getCalTheme();
      if (theme === state.lastTheme) return;
      state.lastTheme = theme;
      initCalEmbed();
    });
    observer.observe(html, { attributes: true, attributeFilter: ['data-theme'] });
    state.observer = observer;
  }

  watchThemeChanges();
  document.addEventListener('astro:page-load', initCalEmbed);
</script>

<style>
  .talk-reveal {
    animation: reveal 400ms ease-out both;
  }

  .talk-header {
    margin-bottom: clamp(1.75rem, 3.5vw, 2.5rem);
  }

  h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }

  .subtitle {
    margin: 0;
    max-width: 60ch;
    color: var(--color-muted);
    font-size: clamp(0.95rem, 1.2vw, 1.05rem);
    line-height: 1.6;
  }

  .cal-inline {
    width: 100%;
    min-height: 640px;
    border-radius: 0.75rem;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
</style>
