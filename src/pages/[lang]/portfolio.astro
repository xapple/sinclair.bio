---
import Layout from '../../layouts/Layout.astro';
import { Languages, useTranslations } from '../../i18n/translations';
import { getCollection } from 'astro:content';
import PackageOpenIcon from '../../assets/icons/package-open.svg?raw';
import QuoteIcon from '../../assets/icons/quote.svg?raw';
import BookIcon from '../../assets/icons/book.svg?raw';
import GraduationCapIcon from '../../assets/icons/graduation-cap.svg?raw';
import OrcidIcon from '../../assets/icons/orcid.svg?raw';

export function getStaticPaths() {
  return Object.values(Languages).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Languages;
const t = useTranslations(lang);
const portfolioEntries = await getCollection('portfolio');
const entry = portfolioEntries.find((e) => e.id === lang);
if (!entry) throw new Error(`No portfolio content found for lang: ${lang}`);
const { testimonials, publications, classes } = entry.data;
---

<Layout lang={lang} title={t('portfolio:page-title')} description={t('meta:portfolio-description')}>
  <section class="portfolio-page">
    <div class="page-shell">
      <div class="section-stack">
        <h2 class="section-heading" id="open-source-heading">
          <span class="icon" aria-hidden="true">
            <Fragment set:html={PackageOpenIcon} />
          </span>
          <span>{t("portfolio:open-source-heading")}</span>
        </h2>

        <div class="card-grid">
          {[1, 2, 3, 4, 5, 6].map((i) => (
            <div class="card">
              <div class="card-thumb"></div>
              <div class="card-body">
                <h3>Project {i}</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.</p>
                <span class="tag">Lorem</span>
                <span class="tag">Ipsum</span>
              </div>
            </div>
          ))}
        </div>

        <h2 class="section-heading" id="testimonials-heading">
          <span class="icon" aria-hidden="true">
            <Fragment set:html={QuoteIcon} />
          </span>
          <span>{t("portfolio:testimonials-heading")}</span>
        </h2>

        <div class="testimonial-list">
          {testimonials.map((testimonial) => (
            <figure class="testimonial">
              <blockquote>"{testimonial.quote}"{testimonial.translated && <span class="translation-note"> {t("portfolio:testimonial-translation-note")}</span>}</blockquote>
              <figcaption>— {testimonial.author}, <span>{testimonial.role}</span></figcaption>
            </figure>
          ))}
        </div>

        <h2 class="section-heading" id="publications-heading">
          <span class="icon" aria-hidden="true">
            <Fragment set:html={BookIcon} />
          </span>
          <span>{t("portfolio:publications-heading")}</span>
        </h2>

        <ul class="publication-list">
          {publications.map((publication) => (
            <li class="publication">
              <p class="pub-title"><a href={publication.href} target="_blank" rel="noopener noreferrer">{publication.title}</a></p>
              <p class="pub-meta">{publication.authors} — <em>{publication.journal}</em>, {publication.year}</p>
            </li>
          ))}
        </ul>

        <p class="orcid-link-wrap">
          <a class="orcid-link" href="https://orcid.org/0000-0003-4134-3571" target="_blank" rel="noopener noreferrer">
            <span class="orcid-icon" aria-hidden="true"><Fragment set:html={OrcidIcon} /></span>
            <span>{t("portfolio:orcid-link")}</span>
            <span class="orcid-arrow" aria-hidden="true">→</span>
          </a>
        </p>

        <h2 class="section-heading" id="classes-heading">
          <span class="icon" aria-hidden="true">
            <Fragment set:html={GraduationCapIcon} />
          </span>
          <span>{t("portfolio:classes-heading")}</span>
        </h2>

        <ul class="publication-list">
          {classes.map((klass) => (
            <li class="publication">
              <p class="pub-title"><a href={klass.href} target="_blank" rel="noopener noreferrer">{klass.title}</a></p>
              <p class="pub-meta">{klass.institution} — {klass.year}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</Layout>

<style>
  .portfolio-page {
    min-height: calc(100vh - 4rem);
    color: var(--color-ink);
    padding: clamp(2rem, 5vw, 5rem) 1.25rem clamp(3rem, 5vw, 4.5rem);
  }

  .page-shell {
    margin: 0 auto;
    width: min(1100px, 100%);
  }

  .section-stack {
    display: grid;
    gap: clamp(1.25rem, 2.5vw, 1.75rem);
  }

  .section-heading {
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.6rem;
    font-size: clamp(1.45rem, 2.6vw, 2.05rem);
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 800;
    color: var(--color-ink);
  }

  .section-heading .icon {
    width: clamp(1.3rem, 2.2vw, 1.85rem);
    height: clamp(1.3rem, 2.2vw, 1.85rem);
    color: var(--color-accent);
    display: inline-flex;
  }

  .section-stack > .section-heading ~ .section-heading {
    margin-top: clamp(2.5rem, 5vw, 4rem);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
    background: var(--color-surface);
    animation: reveal 500ms ease-out both;
  }

  .card:nth-child(1) { animation-delay: 0ms; }
  .card:nth-child(2) { animation-delay: 80ms; }
  .card:nth-child(3) { animation-delay: 160ms; }
  .card:nth-child(4) { animation-delay: 240ms; }
  .card:nth-child(5) { animation-delay: 320ms; }
  .card:nth-child(6) { animation-delay: 400ms; }

  .card-thumb {
    height: 140px;
    background: linear-gradient(135deg, var(--color-border), var(--color-muted));
    opacity: 0.3;
  }

  .card-body {
    padding: 1.25rem;
  }

  .card-body h3 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .card-body p {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    color: var(--color-ink);
    line-height: 1.5;
  }

  .tag {
    display: inline-block;
    margin: 0.25rem 0.25rem 0 0;
    padding: 0.2rem 0.6rem;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }

  .testimonial-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .testimonial {
    margin: 0;
  }

  .testimonial blockquote {
    margin: 0 0 1rem;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-ink);
    opacity: 0.85;
    font-style: italic;
  }

  .testimonial figcaption {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .testimonial figcaption span {
    opacity: 0.7;
  }

  .publication-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }

  .publication {
    border-left: 2px solid color-mix(in srgb, var(--color-accent) 60%, transparent);
    padding: 0.15rem 0 0.15rem 1rem;
  }

  .pub-title {
    margin: 0 0 0.3rem;
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.45;
  }

  .pub-title a {
    color: inherit;
    text-decoration: none;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 60%, transparent);
    text-underline-offset: 3px;
  }

  .pub-title a:hover,
  .pub-title a:focus-visible {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .orcid-link-wrap {
    margin: 0.5rem 0 0;
  }

  .orcid-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .orcid-icon {
    display: inline-flex;
    font-size: 1rem;
    line-height: 1;
  }

  .orcid-icon :global(svg) {
    display: block;
  }

  .orcid-arrow {
    transition: transform 0.15s ease;
  }

  .orcid-link:hover,
  .orcid-link:focus-visible {
    color: var(--color-ink);
  }

  .orcid-link:hover .orcid-arrow,
  .orcid-link:focus-visible .orcid-arrow {
    transform: translateX(2px);
  }

  .pub-meta {
    margin: 0;
    font-size: 0.87rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  @keyframes reveal {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 700px) {
    .portfolio-page {
      padding-inline: 1rem;
    }
  }
</style>
