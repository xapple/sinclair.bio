---
import Layout from '../../layouts/Layout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import Callout from '../../components/Callout.astro';
import RefItem from '../../components/portfolio/RefItem.astro';
import Reveal from '../../components/Reveal.astro';
import { langStaticPaths, getLangEntry } from '../../i18n/page';
import { PROFILES, PUBLICATIONS } from '../../data/profile';
import { PERSONAL } from '../../data/personal';
import { INCLUDE_PERSONAL } from 'astro:env/server';

export const getStaticPaths = langStaticPaths;

const { lang, t } = Astro.locals;
const entry = await getLangEntry('portfolio', lang);
const { projects, testimonials, classes } = entry.data;
const personal = PERSONAL[lang];

// Reveal cascade: each section reveals AFTER the one above it, not in parallel.
// A section's heading shows at its base delay; items stagger STEP ms after it;
// the next section's base is pushed past the current section's last item.
// Chained off the live counts so it stays sequential for any length / language
// -- the portfolio analogue of the journey page's SECTION_DELAY.
const STEP = 80;
const baseOpenSource = 0;
const baseTestimonials = baseOpenSource + (projects.length + 1) * STEP;
const basePublications = baseTestimonials + (testimonials.length + 1) * STEP;
const baseClasses = basePublications + (PUBLICATIONS.length + 1) * STEP;
const basePersonal = baseClasses + (classes.length + 1) * STEP;
---

<Layout
  title={t('portfolio:page-title')}
  description={t('meta:portfolio-description')}
  shellWidth="1100px"
>
  <div class="section-stack">
    <section class="portfolio-section">
      <Reveal delay={baseOpenSource}>
        <SectionHeading icon="package-open" text={t("portfolio:open-source-heading")} id="open-source-heading" />
      </Reveal>

      <div class="card-grid">
        {projects.map((project, i) => (
          <a
            class="card surface-card page-reveal"
            href={project.href}
            target="_blank"
            rel="noopener noreferrer"
            style={`--reveal-delay: ${baseOpenSource + (i + 1) * STEP}ms`}
          >
            <div class:list={["card-thumb", { "has-image": project.image }]}>
              {project.image && <img class="thumb-light" src={project.image} alt="" loading="lazy" decoding="async" />}
              {project.imageDark && <img class="thumb-dark" src={project.imageDark} alt="" loading="lazy" decoding="async" />}
            </div>
            <div class="card-body">
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              {project.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </a>
        ))}
      </div>

      <Callout icon="github" text={t("portfolio:github-link")} href={PROFILES.github} />
    </section>

    <section class="portfolio-section">
      <Reveal delay={baseTestimonials}>
        <SectionHeading icon="quote" text={t("portfolio:testimonials-heading")} id="testimonials-heading" />
      </Reveal>

      <div class="testimonial-list">
        {testimonials.map((testimonial, i) => (
          <figure class="testimonial page-reveal" style={`--reveal-delay: ${baseTestimonials + (i + 1) * STEP}ms`}>
            <blockquote>"{testimonial.quote}"{testimonial.translated && <span class="translation-note"> {t("portfolio:testimonial-translation-note")}</span>}</blockquote>
            <figcaption>— {testimonial.author}, <span>{testimonial.role}</span></figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section class="portfolio-section">
      <Reveal delay={basePublications}>
        <SectionHeading icon="book" text={t("portfolio:publications-heading")} id="publications-heading" />
      </Reveal>

      <ul class="ref-list">
        {PUBLICATIONS.map((publication, i) => (
          <RefItem title={publication.title} href={publication.href} revealDelay={basePublications + (i + 1) * STEP}>
            {publication.authors} — <em>{publication.journal}</em>, {publication.year}
          </RefItem>
        ))}
      </ul>

      <div class="pub-links">
        <Callout icon="scopus" text={t("portfolio:hindex-label")} value={10} href={PROFILES.scopus} />
        <Callout icon="orcid" text={t("portfolio:orcid-link")} href={PROFILES.orcid} />
      </div>
    </section>

    <section class="portfolio-section">
      <Reveal delay={baseClasses}>
        <SectionHeading icon="graduation-cap" text={t("portfolio:classes-heading")} id="classes-heading" />
      </Reveal>

      <ul class="ref-list">
        {classes.map((klass, i) => (
          <RefItem title={klass.title} href={klass.href} revealDelay={baseClasses + (i + 1) * STEP}>
            {klass.institution} — {klass.year}
          </RefItem>
        ))}
      </ul>
    </section>

    {INCLUDE_PERSONAL && (
      <section class="portfolio-section">
        <Reveal delay={basePersonal}>
          <SectionHeading icon="mountain-snow" text={personal.heading} id="personal-heading" />
        </Reveal>

        <Reveal delay={basePersonal + STEP}>
          <p class="m-0 max-w-[60ch] text-base leading-[1.7] text-ink opacity-[0.85]">
            {personal.intro} {personal.linksLabel}<br />
            {personal.favorites.map((fav, i) => (
              <Fragment>
                {i > 0 && <span aria-hidden="true" class="opacity-50">{' · '}</span>}
                <a class="link-underline" href={fav.href} target="_blank" rel="noopener noreferrer">{fav.label}</a>
              </Fragment>
            ))}
          </p>
        </Reveal>
      </section>
    )}
  </div>
</Layout>

<style>
  .section-stack {
    --section-stack-gap: clamp(3rem, 6vw, 4.5rem);
  }

  .portfolio-section {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .card {
    /* Surface, border, and radius come from the shared .surface-card class.
       Entrance fade-up comes from the shared .page-reveal class, staggered via
       the inline --reveal-delay above. */
    display: block;
    color: inherit;
    text-decoration: none;
    transition:
      transform 150ms ease,
      border-color 150ms ease,
      box-shadow 150ms ease;
  }

  /* Unlayered, so the accent border wins over .surface-card's @layer border. */
  .card:hover,
  .card:focus-visible {
    transform: translateY(-3px);
    border-color: var(--color-accent);
    box-shadow: 0 8px 24px -12px rgb(0 0 0 / 0.3);
  }

  .card-thumb {
    height: 140px;
    overflow: hidden;
  }

  /* Decorative gradient placeholder for projects without an image. */
  .card-thumb:not(.has-image) {
    background: linear-gradient(135deg, var(--color-border), var(--color-muted));
    opacity: 0.3;
  }

  /* Light mat: white so transparent logos and white-background plots read. */
  .card-thumb.has-image {
    background: #fff;
    padding: 0.5rem;
  }

  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* Theme-aware image swap. Dark variants are luminance-inverted (a real dark
     capture for the site card), so they sit on a near-black mat. The theme
     toggle sets data-theme="dark" on <html>; these rules follow it. The light variant is
     shown by default; dark mode hides it and reveals .thumb-dark. */
  .card-thumb .thumb-dark {
    display: none;
  }

  :global(html[data-theme="dark"]) .card-thumb.has-image {
    background: #000;
  }

  :global(html[data-theme="dark"]) .card-thumb .thumb-light {
    display: none;
  }

  :global(html[data-theme="dark"]) .card-thumb .thumb-dark {
    display: block;
  }

  .card-body {
    padding: 1.25rem;
  }

  .card-body h3 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .card-body p {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    color: var(--color-ink);
    line-height: 1.5;
  }

  .tag {
    display: inline-block;
    margin: 0.25rem 0.25rem 0 0;
    padding: 0.2rem 0.6rem;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }

  .testimonial-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .testimonial {
    margin: 0;
  }

  .testimonial blockquote {
    margin: 0 0 1rem;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-ink);
    opacity: 0.85;
    font-style: italic;
  }

  .testimonial figcaption {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .testimonial figcaption span {
    opacity: 0.7;
  }

  /* Lay the h-index + ORCID callouts on one line, with a small gap
     between them; wraps to stacked on narrow screens. */
  .pub-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
  }

  .pub-links > :global(p) {
    margin: 0;
  }

  /* Shared by the Publications + Coursework lists; each row is a <RefItem>. */
  .ref-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }
</style>
