---
import Layout from '../../layouts/Layout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { icons } from '../../assets/icons';
import { langStaticPaths, getLangEntry } from '../../i18n/page';

export const getStaticPaths = langStaticPaths;

const { lang, t } = Astro.locals;
const entry = await getLangEntry('portfolio', lang);
const { testimonials, publications, classes } = entry.data;
---

<Layout
  title={t('portfolio:page-title')}
  description={t('meta:portfolio-description')}
  frame="standard"
  shellWidth="1100px"
>
  <div class="section-stack">
    <SectionHeading icon="package-open" text={t("portfolio:open-source-heading")} id="open-source-heading" />

    <div class="card-grid">
      {[1, 2, 3, 4, 5, 6].map((i) => (
        <div class="card" style={`animation-delay: ${(i - 1) * 80}ms`}>
          <div class="card-thumb"></div>
          <div class="card-body">
            <h3>Project {i}</h3>
            <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.</p>
            <span class="tag">Lorem</span>
            <span class="tag">Ipsum</span>
          </div>
        </div>
      ))}
    </div>

    <p class="orcid-link-wrap">
      <a class="orcid-link" href="https://github.com/xapple" target="_blank" rel="noopener noreferrer">
        <span class="orcid-icon" aria-hidden="true"><Fragment set:html={icons.github} /></span>
        <span>{t("portfolio:github-link")}</span>
        <span class="orcid-arrow" aria-hidden="true">→</span>
      </a>
    </p>

    <SectionHeading icon="quote" text={t("portfolio:testimonials-heading")} id="testimonials-heading" />

    <div class="testimonial-list">
      {testimonials.map((testimonial) => (
        <figure class="testimonial">
          <blockquote>"{testimonial.quote}"{testimonial.translated && <span class="translation-note"> {t("portfolio:testimonial-translation-note")}</span>}</blockquote>
          <figcaption>— {testimonial.author}, <span>{testimonial.role}</span></figcaption>
        </figure>
      ))}
    </div>

    <SectionHeading icon="book" text={t("portfolio:publications-heading")} id="publications-heading" />

    <ul class="publication-list">
      {publications.map((publication) => (
        <li class="publication">
          <p class="pub-title"><a href={publication.href} target="_blank" rel="noopener noreferrer">{publication.title}</a></p>
          <p class="pub-meta">{publication.authors} — <em>{publication.journal}</em>, {publication.year}</p>
        </li>
      ))}
    </ul>

    <p class="orcid-link-wrap">
      <a class="orcid-link" href="https://orcid.org/0000-0003-4134-3571" target="_blank" rel="noopener noreferrer">
        <span class="orcid-icon" aria-hidden="true"><Fragment set:html={icons.orcid} /></span>
        <span>{t("portfolio:orcid-link")}</span>
        <span class="orcid-arrow" aria-hidden="true">→</span>
      </a>
    </p>

    <SectionHeading icon="graduation-cap" text={t("portfolio:classes-heading")} id="classes-heading" />

    <ul class="publication-list">
      {classes.map((klass) => (
        <li class="publication">
          <p class="pub-title"><a href={klass.href} target="_blank" rel="noopener noreferrer">{klass.title}</a></p>
          <p class="pub-meta">{klass.institution} — {klass.year}</p>
        </li>
      ))}
    </ul>
  </div>
</Layout>

<style>
  .section-stack > .section-heading ~ .section-heading {
    margin-top: clamp(2.5rem, 5vw, 4rem);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
    background: var(--color-surface);
    animation: reveal 500ms ease-out both;
  }

  .card-thumb {
    height: 140px;
    background: linear-gradient(135deg, var(--color-border), var(--color-muted));
    opacity: 0.3;
  }

  .card-body {
    padding: 1.25rem;
  }

  .card-body h3 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .card-body p {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    color: var(--color-ink);
    line-height: 1.5;
  }

  .tag {
    display: inline-block;
    margin: 0.25rem 0.25rem 0 0;
    padding: 0.2rem 0.6rem;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }

  .testimonial-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .testimonial {
    margin: 0;
  }

  .testimonial blockquote {
    margin: 0 0 1rem;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-ink);
    opacity: 0.85;
    font-style: italic;
  }

  .testimonial figcaption {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .testimonial figcaption span {
    opacity: 0.7;
  }

  .publication-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }

  .publication {
    border-left: 2px solid color-mix(in srgb, var(--color-accent) 60%, transparent);
    padding: 0.15rem 0 0.15rem 1rem;
  }

  .pub-title {
    margin: 0 0 0.3rem;
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.45;
  }

  .pub-title a {
    color: inherit;
    text-decoration: none;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 60%, transparent);
    text-underline-offset: 3px;
  }

  .pub-title a:hover,
  .pub-title a:focus-visible {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .orcid-link-wrap {
    margin: 0.5rem 0 0;
  }

  .orcid-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .orcid-icon {
    display: inline-flex;
    font-size: 1rem;
    line-height: 1;
  }

  .orcid-icon :global(svg) {
    display: block;
    width: 1em;
    height: 1em;
  }

  .orcid-arrow {
    transition: transform 0.15s ease;
  }

  .orcid-link:hover,
  .orcid-link:focus-visible {
    color: var(--color-ink);
  }

  .orcid-link:hover .orcid-arrow,
  .orcid-link:focus-visible .orcid-arrow {
    transform: translateX(2px);
  }

  .pub-meta {
    margin: 0;
    font-size: 0.87rem;
    color: var(--color-muted);
    line-height: 1.5;
  }
</style>
