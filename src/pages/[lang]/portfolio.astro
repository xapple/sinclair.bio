---
import Layout from '../../layouts/Layout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ExternalLinkCallout from '../../components/ExternalLinkCallout.astro';
import HIndexCallout from '../../components/HIndexCallout.astro';
import { langStaticPaths, getLangEntry } from '../../i18n/page';

export const getStaticPaths = langStaticPaths;

const { lang, t } = Astro.locals;
const entry = await getLangEntry('portfolio', lang);
const { projects, testimonials, publications, classes } = entry.data;
---

<Layout
  title={t('portfolio:page-title')}
  description={t('meta:portfolio-description')}
  frame="standard"
  shellWidth="1100px"
>
  <div class="section-stack">
    <section class="portfolio-section">
      <SectionHeading icon="package-open" text={t("portfolio:open-source-heading")} id="open-source-heading" />

      <div class="card-grid">
        {projects.map((project, i) => (
          <a
            class="card surface-card"
            href={project.href}
            target="_blank"
            rel="noopener noreferrer"
            style={`animation-delay: ${i * 80}ms`}
          >
            <div class="card-thumb"></div>
            <div class="card-body">
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              {project.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </a>
        ))}
      </div>

      <ExternalLinkCallout icon="github" text={t("portfolio:github-link")} href="https://github.com/xapple" />
    </section>

    <section class="portfolio-section">
      <SectionHeading icon="quote" text={t("portfolio:testimonials-heading")} id="testimonials-heading" />

      <div class="testimonial-list">
        {testimonials.map((testimonial) => (
          <figure class="testimonial">
            <blockquote>"{testimonial.quote}"{testimonial.translated && <span class="translation-note"> {t("portfolio:testimonial-translation-note")}</span>}</blockquote>
            <figcaption>— {testimonial.author}, <span>{testimonial.role}</span></figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section class="portfolio-section">
      <SectionHeading icon="book" text={t("portfolio:publications-heading")} id="publications-heading" />

      <ul class="publication-list">
        {publications.map((publication) => (
          <li class="publication">
            <p class="pub-title"><a href={publication.href} target="_blank" rel="noopener noreferrer">{publication.title}</a></p>
            <p class="pub-meta">{publication.authors} — <em>{publication.journal}</em>, {publication.year}</p>
          </li>
        ))}
      </ul>

      <div class="pub-links">
        <HIndexCallout label={t("portfolio:hindex-label")} value={10} href="https://www.scopus.com/authid/detail.uri?authorId=56675539100" />
        <ExternalLinkCallout icon="orcid" text={t("portfolio:orcid-link")} href="https://orcid.org/0000-0003-4134-3571" />
      </div>
    </section>

    <section class="portfolio-section">
      <SectionHeading icon="graduation-cap" text={t("portfolio:classes-heading")} id="classes-heading" />

      <ul class="publication-list">
        {classes.map((klass) => (
          <li class="publication">
            <p class="pub-title"><a href={klass.href} target="_blank" rel="noopener noreferrer">{klass.title}</a></p>
            <p class="pub-meta">{klass.institution} — {klass.year}</p>
          </li>
        ))}
      </ul>
    </section>
  </div>
</Layout>

<style>
  .section-stack {
    --section-stack-gap: clamp(3rem, 6vw, 4.5rem);
  }

  .portfolio-section {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .card {
    /* Surface, border, and radius come from the shared .surface-card class. */
    display: block;
    color: inherit;
    text-decoration: none;
    animation: reveal 500ms ease-out both;
    transition:
      transform 150ms ease,
      border-color 150ms ease,
      box-shadow 150ms ease;
  }

  /* Unlayered, so the accent border wins over .surface-card's @layer border. */
  .card:hover,
  .card:focus-visible {
    transform: translateY(-3px);
    border-color: var(--color-accent);
    box-shadow: 0 8px 24px -12px rgb(0 0 0 / 0.3);
  }

  .card-thumb {
    height: 140px;
    background: linear-gradient(135deg, var(--color-border), var(--color-muted));
    opacity: 0.3;
  }

  .card-body {
    padding: 1.25rem;
  }

  .card-body h3 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .card-body p {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    color: var(--color-ink);
    line-height: 1.5;
  }

  .tag {
    display: inline-block;
    margin: 0.25rem 0.25rem 0 0;
    padding: 0.2rem 0.6rem;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }

  .testimonial-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .testimonial {
    margin: 0;
  }

  .testimonial blockquote {
    margin: 0 0 1rem;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-ink);
    opacity: 0.85;
    font-style: italic;
  }

  .testimonial figcaption {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .testimonial figcaption span {
    opacity: 0.7;
  }

  /* Lay the h-index + ORCID callouts on one line, with a small gap
     between them; wraps to stacked on narrow screens. */
  .pub-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
  }

  .pub-links > :global(p) {
    margin: 0;
  }

  .publication-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }

  .publication {
    border-left: 2px solid color-mix(in srgb, var(--color-accent) 60%, transparent);
    padding: 0.15rem 0 0.15rem 1rem;
  }

  .pub-title {
    margin: 0 0 0.3rem;
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.45;
  }

  .pub-title a {
    color: inherit;
    text-decoration: none;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 60%, transparent);
    text-underline-offset: 3px;
  }

  .pub-title a:hover,
  .pub-title a:focus-visible {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .pub-meta {
    margin: 0;
    font-size: 0.87rem;
    color: var(--color-muted);
    line-height: 1.5;
  }
</style>
