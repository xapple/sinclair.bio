---
import Layout from '../../layouts/Layout.astro';
import { Languages, useTranslations } from '../../i18n/translations';
import PackageOpenIcon from '../../assets/icons/package-open.svg?raw';
import QuoteIcon from '../../assets/icons/quote.svg?raw';
import BookIcon from '../../assets/icons/book.svg?raw';
import GraduationCapIcon from '../../assets/icons/graduation-cap.svg?raw';

export function getStaticPaths() {
  return Object.values(Languages).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Languages;
const t = useTranslations(lang);
---

<Layout lang={lang} title="Sinclair | Projects">
  <section class="portfolio-page">
    <div class="page-shell">
      <div class="section-stack">
        <h2 class="section-heading" id="open-source-heading">
          <span class="icon" aria-hidden="true">
            <Fragment set:html={PackageOpenIcon} />
          </span>
          <span>{t("portfolio:open-source-heading")}</span>
        </h2>

        <div class="card-grid">
          {[1, 2, 3, 4, 5, 6].map((i) => (
            <div class="card">
              <div class="card-thumb"></div>
              <div class="card-body">
                <h3>Project {i}</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.</p>
                <span class="tag">Lorem</span>
                <span class="tag">Ipsum</span>
              </div>
            </div>
          ))}
        </div>

        <h2 class="section-heading" id="testimonials-heading">
          <span class="icon" aria-hidden="true">
            <Fragment set:html={QuoteIcon} />
          </span>
          <span>{t("portfolio:testimonials-heading")}</span>
        </h2>

        <div class="testimonial-list">
          <figure class="testimonial">
            <blockquote>"I can wholeheartedly recommend Lucas for scientific website development and online data handling. For our project on tracking the microbiomes of industrial anaerobic digesters, Lucas provided immensely helpful advise on how to best construct an online repository for our data, and also developed a highly professional and stylistic front page. We have also benefited from his experience in choosing the right title for the site. The service was professional and on schedule, and Lucas was great to work with."</blockquote>
            <figcaption>— Orkun Soyer, <span>Professor — University of Warwick</span></figcaption>
          </figure>

          <figure class="testimonial">
            <blockquote>"The metagenomics microbial 16S rRNA pipeline developed by Lucas has been crucial for our gut microbiome projects."</blockquote>
            <figcaption>— Richard Svanbäck, <span>Associate Professor — Uppsala University</span></figcaption>
          </figure>

          <figure class="testimonial">
            <blockquote>"Lucas helped me in 2021, through his company Sinclair Bio, with a total reimplementation of the bioinformatics software CREST that I originally developed during my PhD. It was a pure pleasure to work with Lucas and in addition to writing well structured and state of the art python code, the help and advice he provided, planning the work and resolving different issues, was always very friendly, insightful, skillfull, clear and in prompt. I can warmly recommend Lucas and Sinclair Bio for software development or data analysis tasks related to bioinformatics or to other ends!"</blockquote>
            <figcaption>— Anders Lanzén, <span>Sr. Investigator at AZTI and Ikerbasque Research Fellow</span></figcaption>
          </figure>

          <figure class="testimonial">
            <blockquote>"Lucas was a passionate and motivated Python teacher who was able to pass on not only his knowledge but also his experience to students. His lessons were clear, informative and well organised, allowing students to progress step by step. Feedback from students was very positive. I hope he will return every year to teach this course again."</blockquote>
            <figcaption>— Jenna Lüthi, <span>Head of Web Development — SAE Institute Genève</span></figcaption>
          </figure>

          <figure class="testimonial">
            <blockquote>"Lucas was able to spearhead our bioinformatics analysis pipeline project and bring it to completion in an efficient and timely manner. Working with him was a pleasure and I strongly recommend him."</blockquote>
            <figcaption>— Guansheng Du, Ph.D., <span>Director R&D Microfluidics Platform — Biomillenia</span></figcaption>
          </figure>
        </div>

        <h2 class="section-heading" id="publications-heading">
          <span class="icon" aria-hidden="true">
            <Fragment set:html={BookIcon} />
          </span>
          <span>{t("portfolio:publications-heading")}</span>
        </h2>

        <ul class="publication-list">
          <li class="publication">
            <p class="pub-title"><a href="https://doi.org/10.3390/f12020176" target="_blank" rel="noopener noreferrer">Comparing Reported Forest Biomass Gains and Losses in European and Global Datasets</a></p>
            <p class="pub-meta">Sinclair L., Rougieux P. — <em>Forests</em>, 2021</p>
          </li>
          <li class="publication">
            <p class="pub-title"><a href="https://doi.org/10.7717/peerj.2690" target="_blank" rel="noopener noreferrer">Seqenv: linking sequences to environments through text mining</a></p>
            <p class="pub-meta">Sinclair L., Ijaz U.Z., Jensen L.J., et al. — <em>PeerJ</em>, 2016</p>
          </li>
          <li class="publication">
            <p class="pub-title"><a href="https://doi.org/10.1371/journal.pone.0116955" target="_blank" rel="noopener noreferrer">Microbial Community Composition and Diversity via 16S rRNA Gene Amplicons: Evaluating the Illumina Platform</a></p>
            <p class="pub-meta">Sinclair L., Osman O.A., Bertilsson S., Eiler A. — <em>PLOS One</em>, 2015</p>
          </li>
          <li class="publication">
            <p class="pub-title"><a href="https://doi.org/10.1371/journal.pone.0085879" target="_blank" rel="noopener noreferrer">HTSstation: A Web Application and Open-Access Libraries for High-Throughput Sequencing Data Analysis</a></p>
            <p class="pub-meta">David F.P.A., Delafontaine J., …, Sinclair L., et al. — <em>PLOS One</em>, 2014</p>
          </li>
        </ul>

        <h2 class="section-heading" id="classes-heading">
          <span class="icon" aria-hidden="true">
            <Fragment set:html={GraduationCapIcon} />
          </span>
          <span>{t("portfolio:classes-heading")}</span>
        </h2>

        <ul class="publication-list">
          <li class="publication">
            <p class="pub-title">Lorem ipsum dolor sit amet, consectetur adipiscing elit</p>
            <p class="pub-meta">Lorem University — 2024</p>
          </li>
          <li class="publication">
            <p class="pub-title">Sed do eiusmod tempor incididunt ut labore et dolore magna</p>
            <p class="pub-meta">Ipsum Institute — 2023</p>
          </li>
          <li class="publication">
            <p class="pub-title">Ut enim ad minim veniam, quis nostrud exercitation ullamco</p>
            <p class="pub-meta">Dolor Academy — 2022</p>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Layout>

<style>
  .portfolio-page {
    min-height: calc(100vh - 4rem);
    color: var(--color-ink);
    padding: clamp(2rem, 5vw, 5rem) 1.25rem clamp(3rem, 5vw, 4.5rem);
  }

  .page-shell {
    --section-indent: clamp(1.1rem, 2vw, 1.45rem);
    --section-inner-pad: 1rem;
    margin: 0 auto;
    width: min(1100px, 100%);
  }

  .section-stack {
    display: grid;
    gap: clamp(1.25rem, 2.5vw, 1.75rem);
  }

  .section-heading {
    margin: 0;
    padding-left: calc(var(--section-indent) + var(--section-inner-pad));
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.6rem;
    font-size: clamp(1.45rem, 2.6vw, 2.05rem);
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 800;
    color: var(--color-ink);
  }

  .section-heading .icon {
    width: clamp(1.3rem, 2.2vw, 1.85rem);
    height: clamp(1.3rem, 2.2vw, 1.85rem);
    color: var(--color-accent);
    display: inline-flex;
  }

  .section-stack > .section-heading ~ .section-heading {
    margin-top: clamp(2.5rem, 5vw, 4rem);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    padding-left: calc(var(--section-indent) + var(--section-inner-pad));
  }

  .card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
    background: var(--color-surface);
    animation: reveal 500ms ease-out both;
  }

  .card:nth-child(1) { animation-delay: 0ms; }
  .card:nth-child(2) { animation-delay: 80ms; }
  .card:nth-child(3) { animation-delay: 160ms; }
  .card:nth-child(4) { animation-delay: 240ms; }
  .card:nth-child(5) { animation-delay: 320ms; }
  .card:nth-child(6) { animation-delay: 400ms; }

  .card-thumb {
    height: 140px;
    background: linear-gradient(135deg, var(--color-border), var(--color-muted));
    opacity: 0.3;
  }

  .card-body {
    padding: 1.25rem;
  }

  .card-body h3 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .card-body p {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    color: var(--color-ink);
    line-height: 1.5;
  }

  .tag {
    display: inline-block;
    margin: 0.25rem 0.25rem 0 0;
    padding: 0.2rem 0.6rem;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }

  .testimonial-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-left: calc(var(--section-indent) + var(--section-inner-pad));
  }

  .testimonial {
    margin: 0;
  }

  .testimonial blockquote {
    margin: 0 0 1rem;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-ink);
    opacity: 0.85;
    font-style: italic;
  }

  .testimonial figcaption {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .testimonial figcaption span {
    opacity: 0.7;
  }

  .publication-list {
    list-style: none;
    margin: 0;
    padding-left: calc(var(--section-indent) + var(--section-inner-pad));
    display: grid;
    gap: 1.25rem;
  }

  .publication {
    border-left: 2px solid color-mix(in srgb, var(--color-accent) 60%, transparent);
    padding: 0.15rem 0 0.15rem 1rem;
  }

  .pub-title {
    margin: 0 0 0.3rem;
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.45;
  }

  .pub-title a {
    color: inherit;
    text-decoration: none;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 60%, transparent);
    text-underline-offset: 3px;
  }

  .pub-title a:hover,
  .pub-title a:focus-visible {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .pub-meta {
    margin: 0;
    font-size: 0.87rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  @keyframes reveal {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 700px) {
    .portfolio-page {
      padding-inline: 1rem;
    }

    .page-shell {
      --section-indent: 0.95rem;
      --section-inner-pad: 0.8rem;
    }
  }
</style>
