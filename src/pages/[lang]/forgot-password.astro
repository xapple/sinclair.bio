---
import Layout from '../../layouts/Layout.astro';
import { langStaticPaths, usePage } from '../../i18n/page';

export const getStaticPaths = langStaticPaths;

const { lang, t } = usePage(Astro.params);
const forgotPasswordAction = "https://client.sinclair.bio/forgot-password";
const loginUrl = `/${lang}/login`;
---

<Layout title={t("forgot:page-title")} description={t("meta:forgot-description")} robots="noindex">
  <section class="forgot-page">
    <div class="forgot-shell">
      <header class="forgot-header">
        <h1>{t("forgot:heading")}</h1>
        <p>{t("forgot:intro")}</p>
      </header>

      <form class="forgot-form" action={forgotPasswordAction} method="post">
        <div class="field">
          <label for="email">{t("forgot:email-label")}</label>
          <input
            id="email"
            name="email"
            type="email"
            autocomplete="username"
            placeholder={t("forgot:email-placeholder")}
            required
          />
        </div>

        <button type="submit" class="submit-button">{t("forgot:submit")}</button>
      </form>

      <p class="back-link"><a href={loginUrl}>{t("forgot:back-to-login")}</a></p>
    </div>
  </section>
</Layout>

<style>
  .forgot-page {
    min-height: calc(100vh - 4rem);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.25rem;
    animation: reveal 400ms ease-out both;
  }

  .forgot-shell {
    width: min(420px, 100%);
  }

  .forgot-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }

  .forgot-header p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .forgot-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-surface);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }

  input[type="email"] {
    padding: 0.6rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-bkgnd);
    color: var(--color-ink);
    font-size: 0.95rem;
    font-family: inherit;
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }

  input[type="email"]:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 15%, transparent);
  }

  .submit-button {
    appearance: none;
    width: 100%;
    padding: 0.7rem;
    border-radius: 0.5rem;
    border: none;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: background-color 150ms ease, transform 150ms ease;
  }

  .submit-button:hover {
    background: color-mix(in srgb, var(--color-accent) 88%, black);
  }

  .submit-button:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    outline-offset: 2px;
  }

  .submit-button:active {
    transform: translateY(1px);
  }

  .back-link {
    margin: 1.25rem 0 0;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .back-link a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .back-link a:hover {
    text-decoration: underline;
  }
</style>
