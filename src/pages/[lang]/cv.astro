---
import { Languages, useTranslations } from '../../i18n/translations';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return Object.values(Languages).map((lang) => ({
    params: { lang },
  }));
}

const lang = Astro.params.lang as Languages;
const t = useTranslations(lang);

const cvEntries = await getCollection('cv');
const cvEntry = cvEntries.find((e) => e.id === lang || e.id === `${lang}.json`);
if (!cvEntry) throw new Error(`No CV content found for lang: ${lang}`);
const info = cvEntry.data;

const journeyEntries = await getCollection('journey');
const journeyEntry = journeyEntries.find((e) => e.id === lang || e.id === `${lang}.json`);
if (!journeyEntry) throw new Error(`No journey content found for lang: ${lang}`);
const { experiences } = journeyEntry.data;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{info.name} — CV</title>
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <button class="print-btn" onclick="window.print()">
      {t('cv:print-button')}
    </button>

    <div class="cv">
      <header class="cv-header">
        <div class="cv-name-block">
          <h1>{info.name}</h1>
          <p class="cv-title">{info.title}</p>
        </div>
        <ul class="cv-contact">
          <li>{info.email}</li>
          <li>{info.phone}</li>
          <li>{info.location}</li>
          <li>{info.website}</li>
          <li>{info.linkedin}</li>
        </ul>
      </header>

      <hr />

      <section class="cv-section">
        <h2>{t('cv:experience-heading')}</h2>
        <ol class="cv-experience">
          {experiences.map((item) => (
            <li class="cv-item">
              <div class="cv-item-meta">
                <strong>{item.role}</strong>
                <span>{item.company}</span>
                <span class="cv-period">{item.period}</span>
              </div>
              <p class="cv-summary">{item.summary}</p>
            </li>
          ))}
        </ol>
      </section>
    </div>
  </body>
</html>

<style>
  @page {
    size: A4;
    margin: 2cm 1.5cm;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
    font-size: 11pt;
    color: #111;
    background: #fff;
    padding: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .print-btn {
    display: block;
    margin: 0 0 2rem auto;
    padding: 0.5rem 1.25rem;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.875rem;
    cursor: pointer;
  }

  .cv {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Header */
  .cv-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
  }

  h1 {
    font-size: 22pt;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .cv-title {
    margin-top: 0.35rem;
    font-size: 11pt;
    color: #555;
  }

  .cv-contact {
    list-style: none;
    text-align: right;
    font-size: 9pt;
    color: #444;
    line-height: 1.8;
  }

  hr {
    border: none;
    border-top: 1.5px solid #ddd;
  }

  /* Section */
  .cv-section h2 {
    font-size: 10pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #888;
    margin-bottom: 1rem;
  }

  .cv-experience {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .cv-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1rem;
    break-inside: avoid;
  }

  .cv-item-meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .cv-item-meta strong {
    font-size: 10pt;
    font-weight: 700;
    color: #111;
  }

  .cv-item-meta span {
    font-size: 9pt;
    color: #555;
  }

  .cv-period {
    color: #888 !important;
  }

  .cv-summary {
    font-size: 10pt;
    line-height: 1.6;
    color: #333;
  }

  @media print {
    body {
      padding: 0;
    }

    .print-btn {
      display: none;
    }
  }
</style>
