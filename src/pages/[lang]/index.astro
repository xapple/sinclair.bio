---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/home/HeroSection.astro';
import InfoCardsSection from '../../components/home/InfoCardsSection.astro';
import AboutSection from '../../components/home/AboutSection.astro';
import ContactSection from '../../components/home/ContactSection.astro';
import { langStaticPaths } from '../../i18n/page';

export const getStaticPaths = langStaticPaths;

const { t } = Astro.locals;
---

<Layout title={t('home:page-title')} description={t('meta:home-description')} shellWidth="48rem">
  <HeroSection />
  <InfoCardsSection />
  <AboutSection />
  <ContactSection />
</Layout>
