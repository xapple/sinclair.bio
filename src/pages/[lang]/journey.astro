---
import Layout from '../../layouts/Layout.astro';
import { Languages, useTranslations } from '../../i18n/translations';
import { getCollection } from 'astro:content';
import BriefcaseIcon from '../../assets/icons/briefcase.svg?raw';

export function getStaticPaths() {
  return Object.values(Languages).map((lang) => ({
    params: { lang },
  }));
}

const lang = Astro.params.lang as Languages;
const t = useTranslations(lang);
const journeyEntries = await getCollection('journey');
const entry = journeyEntries.find((e) => e.id === lang || e.id === `${lang}.json`);
if (!entry) throw new Error(`No journey content found for lang: ${lang}`);
const { experiences, education } = entry.data;
---

<Layout lang={lang} title={t('journey:page-title')} description={t('journey:intro')}>
  <section class="journey-page">
    <div class="page-shell">
      <header class="page-header">
        <h1 id="journey-heading">
          <span class="icon" aria-hidden="true">
            <Fragment set:html={BriefcaseIcon} />
          </span>
          <span>{t('journey:heading-start')}</span>
          <span class="accent">{t('journey:heading-accent')}</span>
        </h1>
        <p>{t('journey:intro')}</p>
      </header>

      <div class="section-stack">
        <section class="journey-section" aria-labelledby="experience-heading">
          <div class="section-copy">
            <p class="eyebrow" id="experience-heading">{t('journey:experience-eyebrow')}</p>
          </div>

          <ol class="entry-list">
            {experiences.map((item, index) => (
              <li class="entry-item" style={`--item-index:${index};`}>
                <span class="entry-dot" aria-hidden="true"></span>
                <article class="entry-panel">
                  <div class="entry-meta">
                    <p class="period-badge">{item.period}</p>
                    {item.location && <p class="entry-location">{item.location}</p>}
                  </div>

                  <div class="entry-grid">
                    <div class="entry-heading">
                      <h3>{item.role}</h3>
                      <p class="primary-meta">{item.company}</p>
                      {item.employmentType && <p class="secondary-meta">{item.employmentType}</p>}
                    </div>

                    <div class="entry-body">
                      <p class="summary">{item.summary}</p>
                      {item.highlights && item.highlights.length > 0 && (
                        <ul class="detail-list">
                          {item.highlights.map((highlight) => (
                            <li>{highlight}</li>
                          ))}
                        </ul>
                      )}
                    </div>
                  </div>
                </article>
              </li>
            ))}
          </ol>
        </section>

        <section class="journey-section is-education" aria-labelledby="education-heading">
          <div class="section-copy">
            <p class="eyebrow" id="education-heading">{t('journey:education-eyebrow')}</p>
          </div>

          <ol class="entry-list">
            {education.map((item, index) => (
              <li class="entry-item" style={`--item-index:${index + experiences.length};`}>
                <span class="entry-dot" aria-hidden="true"></span>
                <article class="entry-panel">
                  <div class="entry-meta">
                    <p class="period-badge">{item.period}</p>
                  </div>

                  <div class="entry-grid">
                    <div class="entry-heading">
                      <h3>{item.school}</h3>
                      <p class="primary-meta">{item.degree}</p>
                    </div>

                    <div class="entry-body">
                      <p class="summary">{item.summary}</p>
                      {item.details && item.details.length > 0 && (
                        <ul class="detail-list">
                          {item.details.map((detail) => (
                            <li>{detail}</li>
                          ))}
                        </ul>
                      )}
                    </div>
                  </div>
                </article>
              </li>
            ))}
          </ol>
        </section>
      </div>
    </div>
  </section>
</Layout>

<style>
  .journey-page {
    min-height: calc(100vh - 4rem);
    color: var(--color-ink);
    padding: clamp(2rem, 5vw, 5rem) 1.25rem clamp(3rem, 5vw, 4.5rem);
  }

  .page-shell {
    margin: 0 auto;
    width: min(920px, 100%);
  }

  .page-header {
    margin: 0 auto;
    max-width: 52rem;
    text-align: center;
  }

  .page-header h1 {
    margin: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: clamp(1.65rem, 3vw, 2.45rem);
    line-height: 1;
    letter-spacing: -0.04em;
    font-weight: 800;
  }

  .icon {
    width: clamp(1.45rem, 2.5vw, 2.1rem);
    height: clamp(1.45rem, 2.5vw, 2.1rem);
    color: var(--color-ink);
    display: inline-flex;
  }

  .accent {
    color: var(--color-accent);
  }

  .page-header p {
    margin: 1rem auto 0;
    max-width: 62ch;
    color: var(--color-muted);
    font-size: clamp(0.98rem, 1.2vw, 1.08rem);
    line-height: 1.7;
  }

  .section-stack {
    display: grid;
    gap: clamp(1.5rem, 3vw, 2.25rem);
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
  }

  .journey-section {
    position: relative;
    border: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
    border-radius: 1.6rem;
    padding: clamp(1.3rem, 3.5vw, 2rem);
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--color-accent) 10%, transparent), transparent 38%),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-surface) 82%, var(--color-back) 18%),
        color-mix(in srgb, var(--color-back) 92%, var(--color-surface) 8%)
      );
    box-shadow: 0 18px 50px color-mix(in srgb, var(--color-ink) 8%, transparent);
    overflow: hidden;
  }

  .journey-section::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(135deg, color-mix(in srgb, white 18%, transparent), transparent 45%);
    opacity: 0.35;
  }

  .section-copy {
    position: relative;
    z-index: 1;
    max-width: 42rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--color-accent);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .entry-list {
    --timeline-axis: 0.38rem;
    --entry-indent: clamp(1.1rem, 2vw, 1.45rem);
    position: relative;
    z-index: 1;
    margin: 1rem 0 0;
    padding: 0 0 0 var(--entry-indent);
    list-style: none;
  }

  .entry-list::before {
    content: '';
    position: absolute;
    left: var(--timeline-axis);
    top: 0.25rem;
    bottom: 0.25rem;
    width: 2px;
    background: color-mix(in srgb, var(--color-border) 88%, transparent);
    transform: translateX(-50%);
  }

  .entry-item {
    position: relative;
    padding: 0 0 1.15rem 1rem;
    opacity: 0;
    transform: translateY(14px);
    animation: reveal 560ms ease-out forwards;
    animation-delay: calc(var(--item-index) * 90ms);
  }

  .entry-item:last-child {
    padding-bottom: 0;
  }

  .entry-dot {
    position: absolute;
    left: calc(var(--timeline-axis) - var(--entry-indent));
    top: 1.05rem;
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--color-accent) 12%, transparent);
    transform: translate(-50%, -50%);
  }

  .entry-panel {
    border: 1px solid color-mix(in srgb, var(--color-border) 78%, transparent);
    border-radius: 1.2rem;
    padding: clamp(1rem, 2.4vw, 1.4rem);
    background: color-mix(in srgb, var(--color-back) 84%, var(--color-surface) 16%);
    backdrop-filter: blur(8px);
  }

  .entry-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 0.9rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .period-badge {
    margin: 0;
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.32rem 0.8rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .entry-location {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.87rem;
    line-height: 1.4;
  }

  .entry-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.35fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: start;
  }

  .is-education .entry-grid {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
  }

  .entry-heading h3 {
    margin: 0;
    color: var(--color-ink);
    font-size: clamp(1rem, 1.5vw, 1.26rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 800;
  }

  .primary-meta {
    margin: 0.55rem 0 0;
    color: var(--color-accent);
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .secondary-meta {
    margin: 0.45rem 0 0;
    color: var(--color-muted);
    font-size: 0.77rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .summary {
    margin: 0;
    color: var(--color-ink);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .detail-list {
    margin: 0.95rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.65rem;
  }

  .detail-list li {
    position: relative;
    padding-left: 1rem;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .detail-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62rem;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-accent) 68%, var(--color-border) 32%);
  }

  @keyframes reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 820px) {
    .entry-grid {
      grid-template-columns: 1fr;
      gap: 0.9rem;
    }
  }

  @media (max-width: 700px) {
    .journey-page {
      padding-inline: 1rem;
    }

    .entry-list {
      --timeline-axis: 0.28rem;
      --entry-indent: 0.95rem;
      padding-left: var(--entry-indent);
    }

    .entry-item {
      padding-left: 0.8rem;
    }
  }
</style>
