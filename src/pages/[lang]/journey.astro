---
import Layout from '../../layouts/Layout.astro';
import { Languages, useTranslations } from '../../i18n/translations';
import { getCollection } from 'astro:content';
import BriefcaseIcon from '../../assets/briefcase.svg?raw';

export function getStaticPaths() {
  return Object.values(Languages).map((lang) => ({
    params: { lang },
  }));
}

const lang = Astro.params.lang as Languages;
const t = useTranslations(lang);
const journeyEntries = await getCollection('journey');
const entry = journeyEntries.find((e) => e.id === lang || e.id === `${lang}.json`);
if (!entry) throw new Error(`No journey content found for lang: ${lang}`);
const { experiences } = entry.data;
---

<Layout lang={lang} title={t('journey:page-title')} description={t('journey:intro')}>
  <section class="journey-page">
    <div class="page-shell">
      <header class="page-header">
        <h1 id="journey-heading">
          <span class="icon" aria-hidden="true">
            <Fragment set:html={BriefcaseIcon} />
          </span>
          <span>{t('journey:heading-start')}</span>
          <span class="accent">{t('journey:heading-accent')}</span>
        </h1>
        <p>{t('journey:intro')}</p>
      </header>

      <ol class="timeline" aria-labelledby="journey-heading">
        {experiences.map((item, index) => (
          <li class="timeline-item" style={`--item-index:${index};`}>
            <span class="timeline-dot" aria-hidden="true"></span>
            <div class="timeline-grid">
              <div>
                <h2>{item.role}</h2>
                <p class="company">{item.company}</p>
                <p class="period">{item.period}</p>
              </div>
              <p class="summary">{item.summary}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>
</Layout>

<style>
  .journey-page {
    --mint: #24c79a;
    --mint-strong: #11aa8f;
    --line: #cfd2d8;
    --surface-a: #f7f9fa;
    --surface-b: #eef2f1;
    min-height: calc(100vh - 4rem);
    color: var(--color-ink);
    background:
      radial-gradient(50rem 30rem at 0% 0%, rgba(36, 199, 154, 0.12), transparent 70%),
      radial-gradient(38rem 26rem at 100% 100%, rgba(17, 170, 143, 0.1), transparent 70%),
      linear-gradient(145deg, var(--surface-a) 0%, var(--surface-b) 100%);
    padding: clamp(2rem, 5vw, 5rem) 1.25rem clamp(3rem, 5vw, 4.5rem);
  }

  .page-shell {
    margin: 0 auto;
    width: min(1100px, 100%);
  }

  .page-header h1 {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-family: 'Space Grotesk', 'Avenir Next', 'Segoe UI', sans-serif;
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 800;
  }

  .icon {
    width: clamp(1.45rem, 2.5vw, 2.1rem);
    height: clamp(1.45rem, 2.5vw, 2.1rem);
    color: #1d2028;
    display: inline-flex;
  }

  .accent {
    background: linear-gradient(92deg, var(--mint) 8%, var(--mint-strong) 90%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .page-header p {
    margin: 1rem 0 0;
    max-width: 60ch;
    color: var(--color-muted);
    font-size: clamp(0.98rem, 1.2vw, 1.08rem);
    line-height: 1.6;
  }

  .timeline {
    position: relative;
    margin: clamp(2.5rem, 4vw, 4rem) 0 0;
    padding: 0 0 0 clamp(1.8rem, 3vw, 2.8rem);
    list-style: none;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.4rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: linear-gradient(to bottom, rgba(36, 199, 154, 0.35), var(--line) 28%, var(--line) 72%, rgba(36, 199, 154, 0.35));
  }

  .timeline-item {
    position: relative;
    padding: 0 0 clamp(2.75rem, 6vw, 5rem) clamp(1.5rem, 3vw, 2rem);
    opacity: 0;
    transform: translateY(14px);
    animation: reveal 560ms ease-out forwards;
    animation-delay: calc(var(--item-index) * 130ms);
  }

  .timeline-item:last-child {
    padding-bottom: 0.3rem;
  }

  .timeline-dot {
    position: absolute;
    left: -0.16rem;
    top: 0.4rem;
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 9999px;
    background: var(--mint);
    box-shadow: 0 0 0 10px rgba(36, 199, 154, 0.12);
  }

  .timeline-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
    gap: clamp(1.3rem, 4vw, 4rem);
  }

  h2 {
    margin: 0;
    color: var(--mint-strong);
    font-family: 'Space Grotesk', 'Avenir Next', 'Segoe UI', sans-serif;
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  .company {
    margin: 0.7rem 0 0;
    color: #4c505d;
    font-size: clamp(0.8rem, 1vw, 0.9rem);
    font-weight: 700;
    letter-spacing: 0.015em;
  }

  .period {
    margin: 0.35rem 0 0;
    color: #666d79;
    font-size: clamp(0.75rem, 0.9vw, 0.85rem);
  }

  .summary {
    margin: 0;
    color: var(--color-ink);
    font-size: clamp(0.875rem, 1vw, 1rem);
    line-height: 1.5;
    letter-spacing: -0.015em;
    max-width: 38ch;
  }

  @keyframes reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 950px) {
    .timeline-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .summary {
      max-width: none;
    }
  }

  @media (max-width: 700px) {
    .journey-page {
      padding-inline: 1rem;
    }

    .page-header h1 {
      flex-wrap: wrap;
      gap: 0.6rem;
    }

    .timeline {
      padding-left: 1.1rem;
    }

    .timeline::before {
      left: 0.25rem;
    }

    .timeline-item {
      padding-left: 1rem;
    }

    .timeline-dot {
      left: -0.3rem;
    }
  }

  :global(.dark) .journey-page {
    --line: #4f5669;
    --surface-a: #0f1219;
    --surface-b: #131a22;
  }

  :global(.dark) .icon {
    color: #f2f5ff;
  }

  :global(.dark) .company {
    color: #d7dcef;
  }

  :global(.dark) .period {
    color: #aeb6c9;
  }
</style>
