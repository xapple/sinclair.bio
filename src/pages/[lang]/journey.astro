---
import Layout from '../../layouts/Layout.astro';
import TimelineEntry from '../../components/journey/TimelineEntry.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { langStaticPaths, getLangEntry } from '../../i18n/page';

export const getStaticPaths = langStaticPaths;

const { lang, t } = Astro.locals;
const entry = await getLangEntry('journey', lang);
const { experiences, education, certifications = [] } = entry.data;
---

<Layout title={t('journey:page-title')} description={t('journey:intro')} frame="standard">
  <div class="section-stack">
    <div class="journey-section">
      <SectionHeading icon="briefcase" text={t('journey:experience-eyebrow')} id="experience-heading" />

      <ol class="entry-list" aria-labelledby="experience-heading">
        {experiences.map((item, index) => (
          <TimelineEntry
            layout="wide"
            title={item.role}
            primary={item.company}
            tertiary={item.employmentType}
            period={item.period}
            location={item.location}
            summary={item.summary}
            bullets={item.highlights}
            index={index}
          />
        ))}
      </ol>
    </div>

    <div class="journey-section">
      <SectionHeading icon="graduation-cap" text={t('journey:education-eyebrow')} id="education-heading" />

      <ol class="entry-list" aria-labelledby="education-heading">
        {education.map((item, index) => (
          <TimelineEntry
            layout="narrow"
            title={item.school}
            primary={item.degree}
            tertiary={item.field}
            period={item.period}
            summary={item.summary}
            bullets={item.details}
            index={index}
          />
        ))}
      </ol>
    </div>

    {certifications.length > 0 && (
      <div class="journey-section">
        <SectionHeading icon="certificate" text={t('journey:certifications-eyebrow')} id="certifications-heading" />

        <ol class="entry-list" aria-labelledby="certifications-heading">
          {certifications.map((item, index) => (
            <TimelineEntry
              layout="narrow"
              title={item.name}
              titleHref={item.href}
              primary={item.issuer}
              tertiary={item.field}
              period={item.period}
              summary={item.summary}
              bullets={item.details}
              index={index}
            />
          ))}
        </ol>
      </div>
    )}
  </div>
</Layout>

<style>
  .section-stack {
    /* Indent/pad vars are consumed by .entry-list / .entry-item below.
       Set on the stack so all child sections inherit. */
    --entry-indent: clamp(1.1rem, 2vw, 1.45rem);
    --entry-inner-pad: 1rem;
    --section-stack-gap: clamp(3rem, 6vw, 4.5rem);
  }

  /* Per-section stagger offset — cascades into .entry-item via CSS custom-property inheritance. */
  .journey-section {
    --section-offset: 0ms;
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  .journey-section:nth-child(2) { --section-offset: 300ms; }
  .journey-section:nth-child(3) { --section-offset: 600ms; }

  /* Animated entrance for section headings. */
  .section-heading {
    padding-left: calc(var(--entry-indent) + var(--entry-inner-pad));
    opacity: 0;
    transform: translateY(14px);
    animation: reveal 560ms ease-out forwards;
    animation-delay: var(--section-offset, 0ms);
  }

  .entry-list {
    /* Timeline-axis var feeds entry-dot positioning inside <JourneyEntry>. */
    --timeline-axis: 0.38rem;
    --entry-gap: 1.15rem;
    position: relative;
    margin: 0;
    padding: 0 0 0 var(--entry-indent);
    list-style: none;
  }

  @media (max-width: 700px) {
    .section-stack {
      --entry-indent: 0;
      --entry-inner-pad: 0;
    }
  }
</style>
