---
import Layout from '../../layouts/Layout.astro';
import TimelineEntry from '../../components/journey/TimelineEntry.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import Reveal from '../../components/Reveal.astro';
import { langStaticPaths, getLangEntry } from '../../i18n/page';

export const getStaticPaths = langStaticPaths;

const { lang, t } = Astro.locals;
const entry = await getLangEntry('journey', lang);
const { experiences, education, certifications = [] } = entry.data;

// Per-section base reveal delay (ms): each section's heading reveals after the
// previous section's last row, so the page always cascades top-to-bottom no
// matter how many entries a section has. Chained off the live counts (the
// journey analogue of portfolio.astro's STEP chain) instead of the former
// hardcoded {0,300,600}, which fell out of order once Experience grew past a
// few rows. STEP must equal TimelineEntry's STAGGER_STEP so the section
// headings and their rows share one stagger rhythm.
const STEP = 90;
const SECTION_DELAY = {
  experience: 0,
  education: (experiences.length + 1) * STEP,
  certifications: (experiences.length + 1 + education.length + 1) * STEP,
};
---

<Layout title={t('journey:page-title')} description={t('journey:intro')}>
  <div class="section-stack">
    <div class="journey-section">
      <Reveal delay={SECTION_DELAY.experience}>
        <SectionHeading icon="briefcase" text={t('journey:experience-eyebrow')} id="experience-heading" />
      </Reveal>

      <ol class="entry-list" aria-labelledby="experience-heading">
        {experiences.map((item, index) => (
          <TimelineEntry
            layout="wide"
            baseDelay={SECTION_DELAY.experience}
            title={item.role}
            titleHref={item.href}
            primary={item.company}
            tertiary={item.employmentType}
            logo={item.logo}
            period={item.period}
            location={item.location}
            summary={item.summary}
            bullets={item.highlights}
            index={index}
          />
        ))}
      </ol>
    </div>

    <div class="journey-section">
      <Reveal delay={SECTION_DELAY.education}>
        <SectionHeading icon="graduation-cap" text={t('journey:education-eyebrow')} id="education-heading" />
      </Reveal>

      <ol class="entry-list" aria-labelledby="education-heading">
        {education.map((item, index) => (
          <TimelineEntry
            layout="narrow"
            baseDelay={SECTION_DELAY.education}
            title={item.school}
            titleHref={item.href}
            primary={item.degree}
            tertiary={item.field}
            logo={item.logo}
            period={item.period}
            summary={item.summary}
            bullets={item.details}
            index={index}
          />
        ))}
      </ol>
    </div>

    {certifications.length > 0 && (
      <div class="journey-section">
        <Reveal delay={SECTION_DELAY.certifications}>
          <SectionHeading icon="certificate" text={t('journey:certifications-eyebrow')} id="certifications-heading" />
        </Reveal>

        <ol class="entry-list" aria-labelledby="certifications-heading">
          {certifications.map((item, index) => (
            <TimelineEntry
              layout="narrow"
              baseDelay={SECTION_DELAY.certifications}
              title={item.name}
              titleHref={item.href}
              primary={item.issuer}
              tertiary={item.field}
              logo={item.logo}
              period={item.period}
              summary={item.summary}
              bullets={item.details}
              index={index}
            />
          ))}
        </ol>
      </div>
    )}
  </div>
</Layout>

<style>
  .section-stack {
    /* Indent/pad vars are consumed by .entry-list / .entry-item below.
       Set on the stack so all child sections inherit. */
    --entry-indent: clamp(1.1rem, 2vw, 1.45rem);
    --entry-inner-pad: 1rem;
    --section-stack-gap: clamp(3rem, 6vw, 4.5rem);
  }

  .journey-section {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  /* Align section heading with the indented entry content.
     :global because <SectionHeading> renders the <h2> inside its own component scope. */
  .journey-section :global(.section-heading) {
    padding-left: calc(var(--entry-indent) + var(--entry-inner-pad));
  }

  .entry-list {
    /* Timeline-axis var feeds entry-dot positioning inside <JourneyEntry>. */
    --timeline-axis: 0.38rem;
    --entry-gap: 1.15rem;
    position: relative;
    margin: 0;
    padding: 0 0 0 var(--entry-indent);
    list-style: none;
  }

  @media (max-width: 700px) {
    .section-stack {
      --entry-indent: 0;
      --entry-inner-pad: 0;
    }
  }
</style>
