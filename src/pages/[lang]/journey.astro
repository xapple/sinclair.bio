---
import LangPage from '../../layouts/LangPage.astro';
import JourneyEntry from '../../components/JourneyEntry.astro';
import { Languages, useTranslations } from '../../i18n/translations';
import { langStaticPaths, getLangEntry } from '../../i18n/page';
import BriefcaseIcon from '../../assets/icons/briefcase.svg?raw';
import GraduationCapIcon from '../../assets/icons/graduation-cap.svg?raw';
import CertificateIcon from '../../assets/icons/certificate.svg?raw';

export const getStaticPaths = langStaticPaths;

const lang = Astro.params.lang as Languages;
const t = useTranslations(lang);
const entry = await getLangEntry('journey', lang);
const { experiences, education, certifications = [] } = entry.data;

// Per-section animation base (in stagger units of 90ms).
// Each section gets: heading at base, then item i at base + (i + 1).
// Next section starts after previous section's last item, i.e. prev base + prev item count + 1.
const experiencesBase = 0;
const educationBase = experiencesBase + experiences.length + 1;
const certificationsBase = educationBase + education.length + 1;
---

<LangPage lang={lang} title={t('journey:page-title')} description={t('journey:intro')}>
  <div class="section-stack">
    <div class="journey-section" style={`--section-base:${experiencesBase};`}>
      <h2 class="section-heading" id="experience-heading">
        <span class="icon" aria-hidden="true">
          <Fragment set:html={BriefcaseIcon} />
        </span>
        <span>{t('journey:experience-eyebrow')}</span>
      </h2>

      <ol class="entry-list" aria-labelledby="experience-heading">
        {experiences.map((item, index) => (
          <JourneyEntry
            index={index}
            variant="wide"
            title={item.role}
            subtitle={item.company}
            tertiary={item.employmentType}
            tertiaryStyle="eyebrow"
            period={item.period}
            location={item.location}
            summary={item.summary}
            bullets={item.highlights}
          />
        ))}
      </ol>
    </div>

    <div class="journey-section" style={`--section-base:${educationBase};`}>
      <h2 class="section-heading" id="education-heading">
        <span class="icon" aria-hidden="true">
          <Fragment set:html={GraduationCapIcon} />
        </span>
        <span>{t('journey:education-eyebrow')}</span>
      </h2>

      <ol class="entry-list" aria-labelledby="education-heading">
        {education.map((item, index) => (
          <JourneyEntry
            index={index}
            variant="narrow"
            title={item.school}
            subtitle={item.degree}
            tertiary={item.field}
            period={item.period}
            summary={item.summary}
            bullets={item.details}
          />
        ))}
      </ol>
    </div>

    {certifications.length > 0 && (
      <div class="journey-section" style={`--section-base:${certificationsBase};`}>
        <h2 class="section-heading" id="certifications-heading">
          <span class="icon" aria-hidden="true">
            <Fragment set:html={CertificateIcon} />
          </span>
          <span>{t('journey:certifications-eyebrow')}</span>
        </h2>

        <ol class="entry-list" aria-labelledby="certifications-heading">
          {certifications.map((item, index) => (
            <JourneyEntry
              index={index}
              variant="narrow"
              title={item.name}
              titleHref={item.href}
              subtitle={item.issuer}
              tertiary={item.field}
              period={item.period}
              summary={item.summary}
              bullets={item.details}
            />
          ))}
        </ol>
      </div>
    )}
  </div>
</LangPage>

<style>
  .section-stack {
    /* Indent/pad vars are consumed by .entry-list / .entry-item below.
       Set on the stack so all child sections inherit. */
    --entry-indent: clamp(1.1rem, 2vw, 1.45rem);
    --entry-inner-pad: 1rem;
    --section-stack-gap: clamp(3rem, 6vw, 4.5rem);
  }

  /* Animated entrance for section headings (additive to the global base). */
  .section-heading {
    padding-left: calc(var(--entry-indent) + var(--entry-inner-pad));
    opacity: 0;
    transform: translateY(14px);
    animation: reveal 560ms ease-out forwards;
    animation-delay: calc(var(--section-base, 0) * 90ms);
  }

  .journey-section {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .entry-list {
    /* Timeline-axis var feeds entry-dot positioning inside <JourneyEntry>. */
    --timeline-axis: 0.38rem;
    --entry-gap: 1.15rem;
    position: relative;
    margin: 0;
    padding: 0 0 0 var(--entry-indent);
    list-style: none;
  }

  @media (max-width: 700px) {
    .section-stack {
      --entry-indent: 0;
      --entry-inner-pad: 0;
    }
  }
</style>
