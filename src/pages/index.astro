---
// In production, the Cloudflare Pages Function at functions/index.js intercepts
// `/` and 302s to the locale matching Accept-Language. This static page is only
// served as a fallback (local `astro preview`, or if Functions are disabled).
const defaultTarget = '/en/';
const canonicalUrl = new URL(defaultTarget, Astro.site ?? 'https://sinclair.bio').toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Sinclair.Bio</title>
    <meta name="robots" content="noindex" />
    {/* JS redirect runs first and carries the query string + hash forward
        (utm_*, referrals, etc.). The meta refresh + visible link are the
        no-JS fallbacks; they drop the query string but at least get the
        visitor to the right place. */}
    <script is:inline>
      location.replace('/en/' + location.search + location.hash);
    </script>
    <meta http-equiv="refresh" content={`0; url=${defaultTarget}`} />
    <link rel="canonical" href={canonicalUrl} />
  </head>
  <body>
    <p>Redirecting to <a href={defaultTarget}>Sinclair.Bio</a>…</p>
  </body>
</html>
