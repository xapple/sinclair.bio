---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  heading: string;
  intro: string;
  action: string;
  submitLabel: string;
  sendingLabel?: string;
  successOk?: string;
  errorInvalidCredentials?: string;
  errorRateLimited: string;
  errorGeneric: string;
}

const {
  title,
  description,
  heading,
  intro,
  action,
  submitLabel,
  sendingLabel,
  successOk,
  errorInvalidCredentials,
  errorRateLimited,
  errorGeneric,
} = Astro.props;
---

<Layout title={title} description={description} robots="noindex" frame="centered">
  <header class="auth-header">
    <h1>{heading}</h1>
    <p>{intro}</p>
  </header>

  <form
    class="auth-form"
    action={action}
    method="post"
    data-sending={sendingLabel}
    data-success-ok={successOk}
    data-error-invalid-credentials={errorInvalidCredentials}
    data-error-rate-limited={errorRateLimited}
    data-error-generic={errorGeneric}
  >
    <slot />
    <button type="submit" class="auth-submit">{submitLabel}</button>
  </form>

  <span data-auth-status class="auth-status" role="status" aria-live="polite"></span>

  <p class="auth-footer">
    <slot name="footer" />
  </p>
</Layout>

<script>
  import { initAuthForm } from '../scripts/auth-form';
  initAuthForm();
</script>

<style>
  .auth-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .auth-header h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }

  .auth-header p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-surface);
  }

  /* Slotted form internals use :global() because they live in child markup. */
  .auth-form :global(.field) {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .auth-form :global(label) {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }

  .auth-form :global(input[type="email"]),
  .auth-form :global(input[type="password"]) {
    padding: 0.6rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-bkgnd);
    color: var(--color-ink);
    font-size: 0.95rem;
    font-family: inherit;
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }

  .auth-form :global(input[type="email"]:focus),
  .auth-form :global(input[type="password"]:focus) {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 15%, transparent);
  }

  .auth-form :global(.form-options) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.85rem;
  }

  .auth-form :global(.checkbox-label) {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-ink);
    cursor: pointer;
  }

  .auth-form :global(.checkbox-label input) {
    accent-color: var(--color-accent);
    cursor: pointer;
  }

  .auth-form :global(.forgot-link) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .auth-form :global(.forgot-link:hover) {
    text-decoration: underline;
  }

  .auth-submit {
    appearance: none;
    width: 100%;
    padding: 0.7rem;
    border-radius: 0.5rem;
    border: none;
    background: var(--color-accent);
    /* Use the page background token (near-white in light, near-black in
       dark) so the label stays >= 4.5:1 against accent in both modes —
       pure #fff would drop below AA on the lightened dark accent. */
    color: var(--color-bkgnd);
    font-size: 0.95rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: background-color 150ms ease, transform 150ms ease;
  }

  .auth-submit:hover {
    background: color-mix(in srgb, var(--color-accent) 88%, black);
  }

  .auth-submit:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    outline-offset: 2px;
  }

  .auth-submit:active {
    transform: translateY(1px);
  }

  .auth-status {
    display: block;
    min-height: 1.25rem;
    margin-top: 1rem;
    font-size: 0.9rem;
    text-align: center;
  }

  .auth-status:empty {
    display: none;
  }

  .auth-status--success {
    color: var(--color-accent);
  }

  .auth-status--error {
    color: #d33;
  }

  .auth-footer {
    margin: 1.25rem 0 0;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .auth-footer :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .auth-footer :global(a:hover) {
    text-decoration: underline;
  }
</style>
