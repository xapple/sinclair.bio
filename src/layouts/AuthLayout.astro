---
// Shared chrome for the /login and /forgot pages. Pages supply a `kind` and
// the form's POST URL; this layout resolves every translated string itself
// (heading, intro, submit/sending labels, error messages, page title/meta).
import Layout from './Layout.astro';

interface Props {
  kind: 'login' | 'forgot';
  action: string;
}

const { kind, action } = Astro.props;
const { t } = Astro.locals;
---

<Layout
  title={t(`${kind}:page-title`)}
  description={t(`meta:${kind}-description`)}
  robots="noindex"
  frame="centered"
>
  <header class="auth-header">
    <h1>{t(`${kind}:heading`)}</h1>
    <p>{t(`${kind}:intro`)}</p>
  </header>

  <form
    class="auth-form"
    action={action}
    method="post"
    data-sending={t(`${kind}:submitting`)}
    data-success-ok={kind === 'forgot' ? t('forgot:status-ok') : undefined}
    data-error-invalid-credentials={kind === 'login' ? t('login:error-invalid-credentials') : undefined}
    data-error-rate-limited={t(`${kind}:error-rate-limited`)}
    data-error-generic={t(`${kind}:error-generic`)}
  >
    <slot />
    <button type="submit" class="auth-submit btn-primary">{t(`${kind}:submit`)}</button>
  </form>

  <span data-auth-status class="auth-status" role="status" aria-live="polite"></span>

  <p class="auth-footer">
    <slot name="footer" />
  </p>
</Layout>

<script>
  import { initAuthForm } from '../scripts/auth-form';
  initAuthForm();
</script>

<style>
  .auth-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .auth-header h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }

  .auth-header p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-surface);
  }

  /* Slotted form internals use :global() because they live in child markup. */
  .auth-form :global(.field) {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .auth-form :global(label) {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }

  /* Auth inputs reuse the shared .field-input primitive (set in the page
     markup); these scoped rules add only the auth-specific deltas — a slightly
     different size and a focus ring. :global because the inputs are slotted in
     from the child page. */
  .auth-form :global(.field-input) {
    padding: 0.6rem 0.85rem;
    font-size: 0.95rem;
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }

  .auth-form :global(.field-input:focus) {
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 15%, transparent);
  }

  .auth-form :global(.form-options) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.85rem;
  }

  .auth-form :global(.checkbox-label) {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-ink);
    cursor: pointer;
  }

  .auth-form :global(.checkbox-label input) {
    accent-color: var(--color-accent);
    cursor: pointer;
  }

  .auth-form :global(.forgot-link) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .auth-form :global(.forgot-link:hover) {
    text-decoration: underline;
  }

  /* Visual identity (accent fill, hover, focus, active) comes from the shared
     .btn-primary primitive in global.css; these are only the auth-specific
     size deltas — full-width inside the card, slightly larger. */
  .auth-submit {
    width: 100%;
    padding: 0.7rem;
    font-size: 0.95rem;
  }

  .auth-status {
    display: block;
    min-height: 1.25rem;
    margin-top: 1rem;
    font-size: 0.9rem;
    text-align: center;
  }

  .auth-status:empty {
    display: none;
  }

  .auth-status--success {
    color: var(--color-accent);
  }

  .auth-status--error {
    color: #d33;
  }

  .auth-status :global(small) {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.75rem;
    color: var(--color-muted);
    word-break: break-word;
  }

  .auth-status :global(small)::before {
    content: '("';
  }

  .auth-status :global(small)::after {
    content: '")';
  }

  .auth-footer {
    margin: 1.25rem 0 0;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .auth-footer :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .auth-footer :global(a:hover) {
    text-decoration: underline;
  }
</style>
