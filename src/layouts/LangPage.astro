---
import Layout from './Layout.astro';
import type { Languages } from '../i18n/translations';

interface Props {
  lang: Languages;
  title: string;
  description?: string;
  robots?: string;
  // CSS length used as max width for .page-shell. Defaults to 920px (set in global.css).
  shellWidth?: string;
}

const { lang, title, description, robots, shellWidth } = Astro.props;
const shellStyle = shellWidth ? `--shell-width:${shellWidth};` : undefined;
---

<Layout lang={lang} title={title} description={description} robots={robots}>
  <section class="page-frame">
    <div class="page-shell" style={shellStyle}>
      <slot />
    </div>
  </section>
</Layout>
