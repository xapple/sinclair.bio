---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  robots?: string;
  // CSS length used as max width for .page-shell. Defaults to 920px (set in global.css).
  shellWidth?: string;
}

const { title, description, robots, shellWidth } = Astro.props;
const shellStyle = shellWidth ? `--shell-width:${shellWidth};` : undefined;
---

<Layout title={title} description={description} robots={robots}>
  <section class="page-frame">
    <div class="page-shell" style={shellStyle}>
      <slot />
    </div>
  </section>
</Layout>
