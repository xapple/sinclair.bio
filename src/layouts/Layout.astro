---
import Topbar from '../components/Topbar.astro';
import GridDecoration from '../components/GridDecoration.astro';
import { Languages } from '../i18n/translations';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: Languages;
}

const { title = 'Sinclair.Bio', description, lang = Languages.en } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
<meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#fffff8" />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      // DOMContentLoaded: reveal content after scripts are ready
      document.addEventListener("DOMContentLoaded", function() {
        document.documentElement.dataset.domLoaded = "true";
      });

      function applyTheme() {
        var stored = localStorage.getItem('theme');
        var color = stored === 'dark' || stored === 'light'
          ? stored
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

        // .dark class for Tailwind dark: utilities
        document.documentElement.classList.toggle('dark', color === 'dark');

        // data-theme for custom SVG toggle styling
        document.documentElement.dataset.theme = color;

        // Update meta theme-color for mobile browser chrome.
        // These literals MUST match --color-back in global.css and theme-switcher.ts —
        // CSS variables are not yet available when this blocking script runs.
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute('content', color === 'dark' ? '#140c07' : '#fffff8');

        // Update color-scheme meta
        var csMeta = document.querySelector('meta[name="color-scheme"]');
        if (csMeta) csMeta.content = color;
      }

      // Blocking call on hard navigation (prevents FOUC)
      applyTheme();

      // Re-apply after each SPA swap — ClientRouter resets <html> attrs to the
      // new page's static values, wiping .dark / data-theme / data-dom-loaded.
      document.addEventListener("astro:after-swap", function() {
        applyTheme();
        document.documentElement.dataset.domLoaded = "true";
      });
    </script>
  </head>
  <body class="relative z-0 min-h-screen bg-back text-ink font-sans transition-colors overflow-x-hidden">
    <GridDecoration />
    <Topbar lang={lang} />
    <main class="relative">
      <slot />
    </main>
  </body>
</html>
