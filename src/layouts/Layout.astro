---
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import GridDecoration from '../components/GridDecoration.astro';
import { Languages, useTranslations } from '../i18n/translations';
import { THEME_BACK } from '../scripts/theme-colors';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: Languages;
  robots?: string;
}

const { title = 'Sinclair.Bio', description, lang = Languages.en, robots } = Astro.props;
const t = useTranslations(lang);
const metaDescription = description ?? t('meta:site-description');

// Build absolute URLs for canonical / og:url / hreflang.
// Astro.site is set in astro.config.mjs.
const siteUrl = Astro.site ?? new URL('https://sinclair.bio');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL('/og_card.png', siteUrl).toString();

// Alternate-language URLs for hreflang. Swap the first path segment.
const allLangs = Object.values(Languages);
const alternateLinks = allLangs.map((l) => ({
  hreflang: l,
  href: new URL(
    Astro.url.pathname.replace(new RegExp(`^/${lang}(/|$)`), `/${l}$1`),
    siteUrl,
  ).toString(),
}));
const xDefaultHref = new URL(
  Astro.url.pathname.replace(new RegExp(`^/${lang}(/|$)`), `/en$1`),
  siteUrl,
).toString();

const ogLocaleMap: Record<Languages, string> = {
  [Languages.en]: 'en_US',
  [Languages.fr]: 'fr_FR',
};
const ogLocale = ogLocaleMap[lang];
const ogAlternateLocales = allLangs.filter((l) => l !== lang).map((l) => ogLocaleMap[l]);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Lucas Sinclair',
  url: siteUrl.toString(),
  image: ogImageUrl,
  jobTitle: 'Senior Data Scientist',
  description: t('meta:site-description'),
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Geneva',
    addressCountry: 'CH',
  },
  sameAs: [
    'https://orcid.org/0000-0003-4134-3571',
    'https://github.com/xapple',
    'https://linkedin.com/in/sinclair-bio',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Sinclair.Bio',
  url: siteUrl.toString(),
  inLanguage: lang,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={metaDescription} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="author" content="Lucas Sinclair" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#fffff8" />
    <title>{title}</title>

    <link rel="canonical" href={canonicalUrl} />
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.hreflang} href={link.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sinclair.Bio" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Lucas Sinclair — Senior Data Scientist, PhD in Bioinformatics" />
    <meta property="og:locale" content={ogLocale} />
    {ogAlternateLocales.map((l) => (
      <meta property="og:locale:alternate" content={l} />
    ))}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <ClientRouter />
    <noscript><style>html:not([data-dom-loaded]) main, html:not([data-dom-loaded]) footer { display: block !important; }</style></noscript>
    <script is:inline define:vars={{ THEME_BACK }}>
      // DOMContentLoaded: reveal content after scripts are ready
      document.addEventListener("DOMContentLoaded", function() {
        document.documentElement.dataset.domLoaded = "true";
      });

      function applyTheme() {
        var stored = localStorage.getItem('theme');
        var color = stored === 'dark' || stored === 'light'
          ? stored
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

        // .dark class for Tailwind dark: utilities
        document.documentElement.classList.toggle('dark', color === 'dark');

        // data-theme for custom SVG toggle styling
        document.documentElement.dataset.theme = color;

        // Update meta theme-color for mobile browser chrome.
        // THEME_BACK is injected from src/scripts/theme-colors.ts via define:vars
        // — CSS variables are not yet available when this blocking script runs.
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute('content', THEME_BACK[color]);

        // Update color-scheme meta
        var csMeta = document.querySelector('meta[name="color-scheme"]');
        if (csMeta) csMeta.content = color;
      }

      // Blocking call on hard navigation (prevents FOUC)
      applyTheme();

      // Apply theme to the INCOMING document before the swap. Setting it
      // post-swap leaves a frame where <html> has no data-theme, which makes
      // CSS-transitioned styles (e.g. the theme-switcher knob) animate from
      // default to correct on every navigation.
      document.addEventListener("astro:before-swap", function(e) {
        var stored = localStorage.getItem('theme');
        var color = stored === 'dark' || stored === 'light'
          ? stored
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        var html = e.newDocument.documentElement;
        html.classList.toggle('dark', color === 'dark');
        html.dataset.theme = color;
        html.dataset.domLoaded = "true";
      });

      document.addEventListener("astro:after-swap", function() {
        applyTheme();
        document.documentElement.dataset.domLoaded = "true";
      });
    </script>
  </head>
  <!--
    Body transition is scoped to the two properties that actually change on
    theme toggle (background-color, color). The root view-transition group is
    disabled in global.css, so this fires on theme swap, not SPA navigation.
  -->
  <body class="relative z-0 flex min-h-screen flex-col overflow-x-hidden bg-back font-sans text-ink transition-[background-color,color] duration-150">
    <GridDecoration />
    <Topbar lang={lang} />
    <main class="relative flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
