---
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import GridDecoration from '../components/GridDecoration.astro';
import { Languages } from '../i18n/translations';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: Languages;
}

const { title = 'Sinclair.Bio', description, lang = Languages.en } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
<meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#fffff8" />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      // DOMContentLoaded: reveal content after scripts are ready
      document.addEventListener("DOMContentLoaded", function() {
        document.documentElement.dataset.domLoaded = "true";

        // Restore scroll after a language switch. The language links use
        // data-astro-reload (full reload, no view transition) — see
        // LanguageSwitcher.astro for why. Scroll is saved to sessionStorage
        // on click and restored here once main/footer are visible.
        var langScroll = sessionStorage.getItem('lang-switch-scroll');
        if (langScroll !== null) {
          sessionStorage.removeItem('lang-switch-scroll');
          window.scrollTo(0, parseInt(langScroll, 10));
        }
      });

      function applyTheme() {
        var stored = localStorage.getItem('theme');
        var color = stored === 'dark' || stored === 'light'
          ? stored
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

        // .dark class for Tailwind dark: utilities
        document.documentElement.classList.toggle('dark', color === 'dark');

        // data-theme for custom SVG toggle styling
        document.documentElement.dataset.theme = color;

        // Update meta theme-color for mobile browser chrome.
        // These literals MUST match --color-back in global.css and theme-switcher.ts —
        // CSS variables are not yet available when this blocking script runs.
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute('content', color === 'dark' ? '#140c07' : '#fffff8');

        // Update color-scheme meta
        var csMeta = document.querySelector('meta[name="color-scheme"]');
        if (csMeta) csMeta.content = color;
      }

      function alignJourneyTimeline() {
        window.requestAnimationFrame(function() {
          window.requestAnimationFrame(function() {
            var lists = document.querySelectorAll('.journey-page .entry-list');
            lists.forEach(function(list) {
              var axis = parseFloat(getComputedStyle(list, '::before').left || '0');
              var paddingLeft = parseFloat(getComputedStyle(list).paddingLeft || '0');
              Array.from(list.children).forEach(function(item) {
                var dot = item.querySelector('.entry-dot');
                if (!dot) return;
                dot.style.left = (axis - paddingLeft) + 'px';
                dot.style.transform = 'translate(-50%, -50%)';
              });
            });
          });
        });
      }

      // Blocking call on hard navigation (prevents FOUC)
      applyTheme();
      alignJourneyTimeline();

      // Apply theme to the INCOMING document before the swap. Setting it
      // post-swap leaves a frame where <html> has no data-theme, which makes
      // CSS-transitioned styles (e.g. the theme-switcher knob) animate from
      // default to correct on every navigation.
      document.addEventListener("astro:before-swap", function(e) {
        var stored = localStorage.getItem('theme');
        var color = stored === 'dark' || stored === 'light'
          ? stored
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        var html = e.newDocument.documentElement;
        html.classList.toggle('dark', color === 'dark');
        html.dataset.theme = color;
        html.dataset.domLoaded = "true";
      });

      document.addEventListener("astro:after-swap", function() {
        applyTheme();
        document.documentElement.dataset.domLoaded = "true";
        alignJourneyTimeline();
      });

      document.addEventListener("astro:page-load", alignJourneyTimeline);
      document.addEventListener("DOMContentLoaded", alignJourneyTimeline);
      window.addEventListener("resize", alignJourneyTimeline);
    </script>
  </head>
  <body class="relative z-0 flex min-h-screen flex-col overflow-x-hidden bg-back font-sans text-ink transition-colors">
    <GridDecoration />
    <Topbar lang={lang} />
    <main class="relative flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
