---
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import GridDecoration from '../components/GridDecoration.astro';
import { LANGUAGES, LANGUAGE_LIST, DEFAULT_LANGUAGE } from '../i18n/translations';
import { getAlternatePath } from '../i18n/page';
import { THEME_BKGND, THEME_ACCENT, THEME_BAR } from '../scripts/theme-switcher';
import themeBootstrap from '../scripts/theme-bootstrap.js?raw';
import { buildPersonSchema, buildWebsiteSchema } from '../lib/schema';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  robots?: string;
  // Page shape:
  //   'standard' — wraps slot in .page-frame + .page-shell (content pages)
  //   'centered' — flex-centered card column (auth pages: login, forgot)
  frame?: 'standard' | 'centered';
  // CSS length used as max width for .page-shell.
  // Defaults: 920px for 'standard', 420px for 'centered' (set in global.css).
  shellWidth?: string;
}

const {
  title = 'Sinclair.Bio',
  description,
  robots,
  frame = 'standard',
  shellWidth,
} = Astro.props;
const shellStyle = shellWidth ? `--shell-width:${shellWidth};` : undefined;
const frameClass = frame === 'centered'
  ? 'page-frame page-frame--centered page-reveal'
  : 'page-frame';
const { lang, t } = Astro.locals;
const metaDescription = description ?? t('meta:site-description');

// Build absolute URLs for canonical / og:url / hreflang.
// Astro.site is set in astro.config.mjs.
const siteUrl = Astro.site ?? new URL('https://sinclair.bio');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL('/og_card.png', siteUrl).toString();

// Alternate-language URLs for hreflang. Swap the first path segment.
const alternateLinks = LANGUAGE_LIST.map((l) => ({
  hreflang: l,
  href: new URL(getAlternatePath(lang, l, Astro.url.pathname), siteUrl).toString(),
}));
const xDefaultHref = new URL(
  getAlternatePath(lang, DEFAULT_LANGUAGE, Astro.url.pathname),
  siteUrl,
).toString();

const ogLocale = LANGUAGES[lang].ogLocale;
const ogAlternateLocales = LANGUAGE_LIST
  .filter((l) => l !== lang)
  .map((l) => LANGUAGES[l].ogLocale);

const schemaArgs = { siteUrl, ogImageUrl, lang, t };
const personSchema = buildPersonSchema(schemaArgs);
const websiteSchema = buildWebsiteSchema(schemaArgs);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={metaDescription} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="author" content="Lucas Sinclair" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content={THEME_BAR.light} />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content={THEME_BAR.dark} />
    <title>{title}</title>

    <link rel="canonical" href={canonicalUrl} />
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.hreflang} href={link.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sinclair.Bio" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Lucas Sinclair — Senior Data Scientist, PhD in Bioinformatics" />
    <meta property="og:locale" content={ogLocale} />
    {ogAlternateLocales.map((l) => (
      <meta property="og:locale:alternate" content={l} />
    ))}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <noscript><style>html:not([data-dom-loaded]) main, html:not([data-dom-loaded]) footer { visibility: visible !important; }</style></noscript>
    <!-- Single source of truth for theme hex values. Pushed into CSS as
         --theme-bkgnd-{light,dark} and --theme-accent-{light,dark}, which
         global.css's @theme + [data-theme] blocks reference. -->
    <style is:global is:inline set:html={`:root { --theme-bkgnd-light: ${THEME_BKGND.light}; --theme-bkgnd-dark: ${THEME_BKGND.dark}; --theme-accent-light: ${THEME_ACCENT.light}; --theme-accent-dark: ${THEME_ACCENT.dark}; --theme-bar-light: ${THEME_BAR.light}; --theme-bar-dark: ${THEME_BAR.dark}; }`} />
    <!-- Blocking theme bootstrap. Source: src/scripts/theme-bootstrap.js,
         imported as raw text and inlined here so it runs before bundles load.
         THEME_BAR comes from theme-switcher.ts via define:vars and sets the
         <meta theme-color> tags to the topbar color for the current theme. -->
    <script is:inline define:vars={{ THEME_BAR }} set:html={themeBootstrap} />
  </head>
  <!-- Body is the bar color, not the page background: Safari 26 derives its
       toolbar tint from the <body> background, so a bar-colored body keeps the
       browser chrome the same brown as the topbar — including the brief window
       during a cross-document navigation when the new page's sticky topbar
       isn't sampled yet (otherwise the chrome flashes to the page background).
       The cream page background lives on <main> instead, which fills the space
       between the topbar and footer; the body color shows only on overscroll,
       where it matches the topbar and footer. -->
  <body class="relative z-0 flex min-h-screen flex-col overflow-x-hidden bg-bar font-sans text-ink transition-[background-color,color] duration-150">
    <Topbar />
    <main class="relative z-0 flex-1 bg-bkgnd transition-[background-color] duration-150">
      <GridDecoration />
      <section class={frameClass}>
        <div class="page-shell" style={shellStyle}>
          <slot />
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
