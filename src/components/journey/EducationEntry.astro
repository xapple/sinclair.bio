---
import TimelineEntry from './TimelineEntry.astro';

interface Props {
  school: string;
  degree: string;
  field?: string;
  period: string;
  summary: string;
  details?: string[];
  index: number;
}

const { school, degree, field, period, summary, details, index } = Astro.props;
---

<TimelineEntry
  kind="education"
  title={school}
  primary={degree}
  tertiary={field}
  period={period}
  summary={summary}
  bullets={details}
  index={index}
/>
