---
import TimelineEntry from './TimelineEntry.astro';

interface Props {
  name: string;
  href?: string;
  issuer: string;
  field?: string;
  period: string;
  summary: string;
  details?: string[];
  index: number;
}

const { name, href, issuer, field, period, summary, details, index } = Astro.props;
---

<TimelineEntry
  kind="education"
  title={name}
  titleHref={href}
  primary={issuer}
  tertiary={field}
  period={period}
  summary={summary}
  bullets={details}
  index={index}
/>
