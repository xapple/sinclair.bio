---
import Icon from '../Icon.astro';

// Visual primitive for journey timeline rows.
//
// `layout` controls two coupled visual choices:
//   'wide'    — wider body column, uppercase letterspaced tertiary line
//   'narrow'  — more even columns, plain muted tertiary line
interface Props {
  layout: 'wide' | 'narrow';
  // Primary heading (role / school / cert name). Renders as a link if titleHref is set.
  title: string;
  titleHref?: string;
  // Accent-coloured line under the title (company / degree / issuer).
  primary: string;
  // Optional third line (employmentType / field of study).
  tertiary?: string;
  // Optional brand mark (icon basename) shown under the heading, right-aligned.
  logo?: string;
  period: string;
  location?: string;
  summary: string;
  bullets?: string[];
  // Zero-based position within its section — drives the stagger animation.
  index: number;
  // Base reveal delay (ms) for this entry's section; rows stagger after it.
  baseDelay?: number;
}

const { layout, title, titleHref, primary, tertiary, logo, period, location, summary, bullets, index, baseDelay = 0 } = Astro.props;

const variantClass = layout === 'wide' ? 'entry-item--wide' : 'entry-item--narrow';
const tertiaryClass = layout === 'wide' ? 'secondary-meta' : 'field-meta';

// Stagger: each row reveals STAGGER_STEP ms after the previous, offset by the
// section's baseDelay. (index + 1) so the first row trails its section heading.
const STAGGER_STEP = 90;
const revealDelay = baseDelay + (index + 1) * STAGGER_STEP;
---

<li class={`entry-item ${variantClass} page-reveal`} style={`--reveal-delay:${revealDelay}ms;`}>
  <span class="entry-dot" aria-hidden="true"></span>
  <article class="entry-panel surface-card">
    <div class="entry-left">
      <div class="entry-meta">
        <p class="period-badge">{period}</p>
        {location && <p class="entry-location">{location}</p>}
      </div>

      <div class="entry-heading">
        {titleHref ? (
          <a class="entry-heading-link" href={titleHref} target="_blank" rel="noopener noreferrer">
            <h3>{title}</h3>
            <p class="primary-meta">{primary}</p>
          </a>
        ) : (
          <Fragment>
            <h3>{title}</h3>
            <p class="primary-meta">{primary}</p>
          </Fragment>
        )}
        {tertiary && <p class={tertiaryClass}>{tertiary}</p>}
      </div>

      {logo && (
        <div class="entry-logo" data-logo={logo}>
          <Icon name={logo} size="lg" />
        </div>
      )}
    </div>

    <div class="entry-body">
      <p class="summary">{summary}</p>
      {bullets && bullets.length > 0 && (
        <ul class="detail-list">
          {bullets.map((b) => <li>{b}</li>)}
        </ul>
      )}
    </div>
  </article>
</li>

<style>
  .entry-item {
    position: relative;
    padding: 0 0 0 var(--entry-inner-pad);
    margin-bottom: var(--entry-gap);
    /* Entrance fade-up comes from the shared .page-reveal class; --reveal-delay
       is set inline per row (section baseDelay + staggered index). */
  }

  .entry-item:last-child {
    margin-bottom: 0;
  }

  .entry-item::before {
    content: '';
    position: absolute;
    left: calc(var(--timeline-axis) - var(--entry-indent));
    top: 0;
    bottom: calc(-1 * var(--entry-gap));
    width: 2px;
    background: color-mix(in srgb, var(--color-border) 88%, transparent);
    transform: translateX(-50%);
  }

  .entry-item:first-child::before {
    top: 50%;
  }

  .entry-item:last-child::before {
    bottom: 50%;
  }

  .entry-dot {
    position: absolute;
    left: calc(var(--timeline-axis) - var(--entry-indent));
    top: 50%;
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--color-accent) 12%, transparent);
    transform: translate(-50%, -50%);
  }

  .entry-panel {
    /* Surface fill + border come from the shared .surface-card class; we keep
       the larger panel radius via its --card-radius override. */
    --card-radius: 1.2rem;
    padding: clamp(1rem, 2.4vw, 1.4rem);
    display: grid;
    gap: clamp(1rem, 3vw, 2rem);
    align-items: start;
  }

  .entry-item--wide   .entry-panel { grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.35fr); }
  .entry-item--narrow .entry-panel { grid-template-columns: minmax(0, 1fr)    minmax(0, 1.15fr); }

  .entry-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 0.9rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .period-badge {
    margin: 0;
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.32rem 0.8rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .entry-location {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.87rem;
    line-height: 1.4;
  }

  .entry-heading h3 {
    margin: 0;
    color: var(--color-ink);
    font-size: clamp(1rem, 1.5vw, 1.26rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 800;
  }

  /* Combined link: title + subtitle hover and trigger together. */
  .entry-heading-link {
    display: block;
    color: inherit;
    text-decoration: none;
    border-radius: 0.4rem;
  }

  .entry-heading-link h3 {
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 55%, transparent);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
    transition: color 160ms ease;
  }

  .entry-heading-link:hover h3,
  .entry-heading-link:focus-visible h3 {
    color: var(--color-accent);
  }

  .entry-heading-link:hover .primary-meta,
  .entry-heading-link:focus-visible .primary-meta {
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 55%, transparent);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
  }

  .primary-meta {
    margin: 0.55rem 0 0;
    color: var(--color-accent);
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .field-meta {
    margin: 0.2rem 0 0;
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .secondary-meta {
    margin: 0.45rem 0 0;
    color: var(--color-muted);
    font-size: 0.77rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* Brand mark under the heading, left-aligned in the left column.
     Inherits currentColor from the muted tone so it flips with the theme. */
  .entry-logo {
    display: flex;
    justify-content: flex-start;
    margin-top: 0.7rem;
    color: var(--color-muted);
    opacity: 0.85;
  }

  /* Size by the wordmark's height; width follows the cropped aspect ratio so
     there's no transparent padding around the mark. :global because the .icon
     span + svg are rendered by <Icon>, outside this component's style scope. */
  .entry-logo :global(.icon) {
    width: auto;
    height: 1.8rem;
  }

  .entry-logo :global(.icon > svg) {
    width: auto;
  }

  /* The EU emblem is sparser than the wordmarks, so it carries 1.5× the
     shared height (1.8rem) for comparable visual weight. */
  .entry-logo[data-logo='european-commission'] :global(.icon) {
    height: 2.7rem;
  }

  /* UNIGE seal + wordmark reads small at the shared height; nudged to 36px. */
  .entry-logo[data-logo='university-of-geneva'] :global(.icon) {
    height: 2.25rem;
  }

  /* Envonautics is a tall, narrow mark — 2× the shared height for presence. */
  .entry-logo[data-logo='envonautics'] :global(.icon) {
    height: 3.6rem;
  }

  /* Uppsala seal is detailed; 1.8× the base height so the engraving reads. */
  .entry-logo[data-logo='uppsala-university'] :global(.icon) {
    height: 3.24rem;
  }

  .summary {
    margin: 0;
    color: var(--color-ink);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .detail-list {
    margin: 0.95rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.65rem;
  }

  .detail-list li {
    position: relative;
    padding-left: 1rem;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .detail-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62rem;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-accent) 68%, var(--color-border) 32%);
  }

  @media (max-width: 820px) {
    /* Match variant selectors' specificity so they don't override the collapse. */
    .entry-item--wide .entry-panel,
    .entry-item--narrow .entry-panel {
      grid-template-columns: 1fr;
      gap: 0.9rem;
    }
  }

  @media (max-width: 700px) {
    .entry-dot,
    .entry-item::before {
      display: none;
    }
  }
</style>
