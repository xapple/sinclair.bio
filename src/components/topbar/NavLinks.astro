---
const { lang, t } = Astro.locals;
const currentPath = Astro.url.pathname;

const links = [
  { label: t('nav:contact'), href: `/${lang}/` },
  { label: t('nav:journey'), href: `/${lang}/journey` },
  { label: t('nav:portfolio'), href: `/${lang}/portfolio` },
  { label: t('nav:talk'), href: `/${lang}/talk` },
];

const activeClasses = 'rounded-md px-3 py-2 text-base font-semibold text-bar-fg bg-white/10';
const inactiveClasses = 'rounded-md px-3 py-2 text-base font-medium text-bar-fg/85 hover:bg-white/10 hover:text-bar-fg transition-colors';

function isActive(href: string): boolean {
  // Strip hash for comparison — hash links all belong to the same page
  const hrefPath = href.split('#')[0].replace(/\/$/, '');
  const normalizedCurrentPath = currentPath.replace(/\/$/, '');

  return (
    normalizedCurrentPath === hrefPath ||
    (hrefPath !== `/${lang}` && normalizedCurrentPath.startsWith(`${hrefPath}/`))
  );
}
---

{links.map(({ label, href }) =>
  isActive(href) ? (
    <span class={activeClasses} aria-current="page">
      <span class="nav-label" data-label={label}>{label}</span>
    </span>
  ) : (
    <a href={href} class={inactiveClasses}>
      <span class="nav-label" data-label={label}>{label}</span>
    </a>
  )
)}

<style>
  .nav-label::after {
    content: attr(data-label);
    font-weight: 600; /* semibold — reserves bold width */
    display: block;
    height: 0;
    visibility: hidden;
    overflow: hidden;
  }
</style>
