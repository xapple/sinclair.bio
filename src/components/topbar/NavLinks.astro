---
import { useTranslations, Languages } from '../../i18n/translations';

interface Props {
  mobile?: boolean;
  lang?: Languages;
}

const { mobile = false, lang = Languages.en } = Astro.props;
const t = useTranslations(lang);

const links = [
  { label: t('nav:home'), href: `/${lang}/` },
  { label: t('nav:journey'), href: `/${lang}/journey` },
  { label: t('nav:projects'), href: `/${lang}/#projects` },
  { label: t('nav:quote'), href: `/${lang}/#quote` },
  { label: t('nav:contact'), href: `/${lang}/#contact` },
];

const baseClasses = mobile
  ? 'block rounded-md px-3 py-2 text-base font-medium text-bar-fg/70 hover:bg-white/10 hover:text-bar-fg transition-colors'
  : 'rounded-md px-3 py-2 text-sm font-medium text-bar-fg/60 hover:bg-white/10 hover:text-bar-fg transition-colors';
---

{links.map(({ label, href }) => (
  <a href={href} class={baseClasses}>
    {label}
  </a>
))}
