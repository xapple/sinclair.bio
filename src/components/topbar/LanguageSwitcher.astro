---
import { Languages, getLangFromUrl } from '../../i18n/translations';
import { getAlternatePath } from '../../i18n/page';
import LanguageSwitcherDesktop, { type LangLink } from './LanguageSwitcherDesktop.astro';
import LanguageSwitcherMobile from './LanguageSwitcherMobile.astro';

const currentLang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

const langLinks: LangLink[] = Object.values(Languages).map((l) => ({
  lang: l,
  href: l === currentLang ? null : getAlternatePath(currentLang, l, currentPath),
  label: l.toUpperCase(),
}));

const activeIndex = langLinks.findIndex((link) => link.href === null);
---

<LanguageSwitcherDesktop langLinks={langLinks} activeIndex={activeIndex} />
<LanguageSwitcherMobile currentLang={currentLang} langLinks={langLinks} />
