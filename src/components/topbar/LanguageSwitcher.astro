---
import { Languages, getLangFromUrl, useTranslations } from '../../i18n/translations';
import globeSvg from '../../assets/icons/globe.svg?raw';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

/**
 * Compute the alternate-language path.
 * With prefixDefaultLocale: true, URLs are always /{lang}/...
 * Swapping language = replacing the first path segment.
 */
function getAlternatePath(
  currentLang: Languages,
  targetLang: Languages,
  path: string
): string {
  return path.replace(
    new RegExp(`^/${currentLang}(/|$)`),
    `/${targetLang}$1`
  );
}

interface LangLink {
  lang: Languages;
  href: string | null; // null = current language (not clickable)
  label: string;
}

const langLinks: LangLink[] = Object.values(Languages).map((l) => ({
  lang: l,
  href: l === lang ? null : getAlternatePath(lang, l, currentPath),
  label: l.toUpperCase(),
}));

const activeIndex = langLinks.findIndex((link) => link.href === null);
---

<!-- Full pill switcher — desktop only -->
<div class="language-switcher-desktop relative hidden overflow-hidden rounded-md border border-white/20 md:grid" style={`--lang-count:${langLinks.length};`}>
  <span
    transition:name="language-switcher-active"
    aria-hidden="true"
    class="language-switcher-active pointer-events-none absolute inset-y-0 left-0 z-0 rounded-[5px] bg-bar-fg"
    style={`--lang-index:${activeIndex};`}
  ></span>

  {langLinks.map((link) => {
    const isActive = link.href === null;
    const itemClasses = [
      'relative z-10 flex items-center justify-center px-2.5 py-1.5 text-sm font-medium leading-none whitespace-nowrap',
      isActive
        ? 'text-bar'
        : 'text-bar-fg/60 transition-colors hover:text-bar-fg',
    ];

    return isActive ? (
      <span
        transition:name="language-switcher-active-label"
        class:list={itemClasses}
        aria-current="true"
      >
        {link.label}
      </span>
    ) : (
      <a
        href={link.href}
        rel="alternate"
        hreflang={link.lang}
        class:list={itemClasses}
      >
        {link.label}
      </a>
    );
  })}
</div>

<!-- Compact globe dropdown — mobile only -->
<div class="relative md:hidden">
  <button
    id="lang-dropdown-toggle"
    class="relative flex items-center justify-center w-11 h-11 text-bar-fg cursor-pointer hover:bg-white/10 transition-colors rounded-md"
    aria-expanded="false"
    aria-label={t('a11y:select-language')}
  >
    <!-- Globe icon + badge, positioned relative to the icon -->
    <span class="relative w-6 h-6" aria-hidden="true">
      <Fragment set:html={globeSvg} />
      <span class="lang-badge absolute -bottom-0.5 -right-1 text-[7px] font-bold leading-none bg-bar-fg text-bar rounded px-[3px] py-[2px]">
        {lang.toUpperCase()}
      </span>
    </span>
  </button>

  <!-- Dropdown menu -->
  <div
    id="lang-dropdown"
    class="hidden absolute right-0 top-full mt-1 min-w-[4rem] rounded-md bg-bar border border-white/20 overflow-hidden shadow-lg"
    role="menu"
  >
    {langLinks.map((link) => {
      const isActive = link.href === null;
      return isActive ? (
        <span
          class="block px-4 py-2 text-sm font-medium text-bar-fg bg-white/10"
          role="menuitem"
          aria-current="true"
        >
          {link.label}
        </span>
      ) : (
        <a
          href={link.href}
          rel="alternate"
          hreflang={link.lang}
          class="block px-4 py-2 text-sm font-medium text-bar-fg/60 hover:bg-white/10 hover:text-bar-fg transition-colors"
          role="menuitem"
        >
          {link.label}
        </a>
      );
    })}
  </div>
</div>

<script>
  // One-time: close dropdown when clicking outside (queries fresh elements each call)
  document.addEventListener('click', () => {
    const dropdown = document.getElementById('lang-dropdown');
    const toggle = document.getElementById('lang-dropdown-toggle');
    if (!dropdown?.classList.contains('hidden')) {
      dropdown?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });

  // Re-run on every navigation (fresh DOM elements need fresh listeners)
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('lang-dropdown-toggle');
    const dropdown = document.getElementById('lang-dropdown');

    toggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = dropdown?.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    // Preserve scroll across language navigation. ClientRouter resets scroll
    // to 0 on every swap; without this restore, switching language while
    // scrolled would jump the user to the top of the new translation.
    document.querySelectorAll<HTMLAnchorElement>('a[hreflang]').forEach((link) => {
      link.addEventListener('click', () => {
        sessionStorage.setItem('lang-switch-scroll', String(window.scrollY));
      });
    });
  });

  document.addEventListener('astro:after-swap', () => {
    const saved = sessionStorage.getItem('lang-switch-scroll');
    if (saved !== null) {
      sessionStorage.removeItem('lang-switch-scroll');
      window.scrollTo({ top: parseInt(saved, 10), left: 0, behavior: 'instant' });
    }
  });
</script>

<style is:global>
  .language-switcher-desktop {
    grid-template-columns: repeat(var(--lang-count), minmax(0, 1fr));
  }

  .language-switcher-active {
    width: calc(100% / var(--lang-count));
    transform: translateX(calc(var(--lang-index) * 100%));
  }

  ::view-transition-group(language-switcher-active) {
    animation-duration: 360ms;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    ::view-transition-group(language-switcher-active) {
      animation-duration: 0.01ms;
    }
  }

  #lang-dropdown-toggle svg {
    width: 1.5rem;
    height: 1.5rem;
  }
</style>
