---
import Icon from '../Icon.astro';
import { LANGUAGES, LANGUAGE_LIST, type Language } from '../../i18n/translations';
import { getAlternatePath } from '../../i18n/page';

interface LangLink {
  lang: Language;
  href: string | null; // null = current language (not clickable)
  label: string;
  fullLabel: string;
  flag: string;
}

const { lang: currentLang, t } = Astro.locals;
const currentPath = Astro.url.pathname;

const langLinks: LangLink[] = LANGUAGE_LIST.map((l) => ({
  lang: l,
  href: l === currentLang ? null : getAlternatePath(currentLang, l, currentPath),
  label: l.toUpperCase(),
  fullLabel: LANGUAGES[l].fullLabel,
  flag: LANGUAGES[l].flag,
}));

const activeIndex = langLinks.findIndex((link) => link.href === null);
---

<!-- Desktop: inline pill toggle with animated active indicator. -->
<div
  class="language-switcher-desktop relative hidden overflow-hidden rounded-md border border-white/20 md:grid"
  style={`--lang-count:${langLinks.length};`}
  data-lang-index={activeIndex}
>
  <span
    aria-hidden="true"
    class="language-switcher-active pointer-events-none absolute inset-y-0 left-0 z-0 rounded-[5px] bg-bar-fg"
    style={`--lang-index:${activeIndex};`}
  ></span>

  {langLinks.map((link, slot) => {
    const isActive = link.href === null;
    const itemClasses = [
      'relative z-10 flex items-center justify-center px-2.5 py-1.5 text-sm font-medium leading-none whitespace-nowrap',
      isActive
        ? 'text-bar'
        : 'text-bar-fg/60 transition-colors hover:text-bar-fg',
    ];

    return isActive ? (
      <span class:list={itemClasses} aria-current="true">
        {link.label}
      </span>
    ) : (
      <a
        href={link.href}
        rel="alternate"
        hreflang={link.lang}
        data-slot={slot}
        class:list={itemClasses}
      >
        {link.label}
      </a>
    );
  })}
</div>

<!-- Mobile: globe icon + dropdown menu. -->
<div class="relative md:hidden">
  <button
    id="lang-dropdown-toggle"
    class="bar-icon-btn relative"
    aria-expanded="false"
    aria-label={t('a11y:select-language')}
  >
    <span class="relative" aria-hidden="true">
      <Icon name="globe" size="md" />
      <span class="lang-badge absolute -bottom-0.5 -right-1 text-[7px] font-bold leading-none bg-bar-fg text-bar rounded px-[3px] py-[2px]">
        {currentLang.toUpperCase()}
      </span>
    </span>
  </button>

  <div
    id="lang-dropdown"
    class="hidden absolute right-0 top-full mt-1 rounded-md bg-bar border border-white/20 overflow-hidden shadow-lg"
    role="menu"
  >
    {langLinks.map((link) => {
      const isActive = link.href === null;
      return isActive ? (
        <span
          class="flex items-center gap-2 px-4 py-3 text-base font-medium text-bar-fg bg-white/10 whitespace-nowrap"
          role="menuitem"
          aria-current="true"
        >
          <span aria-hidden="true">{link.flag}</span>
          {link.fullLabel}
        </span>
      ) : (
        <a
          href={link.href}
          rel="alternate"
          hreflang={link.lang}
          class="flex items-center gap-2 px-4 py-3 text-base font-medium text-bar-fg/60 hover:bg-white/10 hover:text-bar-fg transition-colors whitespace-nowrap"
          role="menuitem"
        >
          <span aria-hidden="true">{link.flag}</span>
          {link.fullLabel}
        </a>
      );
    })}
  </div>
</div>

<style>
  .language-switcher-desktop {
    grid-template-columns: repeat(var(--lang-count), minmax(0, 1fr));
  }

  .language-switcher-active {
    width: calc(100% / var(--lang-count));
    transform: translateX(calc(var(--lang-index) * 100%));
    /* Drives the cross-page FLIP slide (and nothing else: --lang-index is
       static per page, so the transition only ever fires when the hold rule
       below releases). global.css's prefers-reduced-motion block zeroes it. */
    transition: transform 360ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* The active label crossfades on the same clock as the pill's FLIP
     release; its hold-state color is set in the global block below. */
  .language-switcher-desktop [aria-current] {
    transition: color 360ms cubic-bezier(0.22, 1, 0.36, 1);
  }
</style>

<style is:global>
  /* FLIP hold — global because it keys off a class the inline bootstrap
     (src/scripts/lang-pill-slide.js, in Layout's <head>) sets on <html>
     before first paint: while present, the pill sits at the slot it
     occupied on the previous page; the bootstrap removes the class one
     painted frame later and the scoped transitions slide everything home.

     The labels ride along so the held switcher still reads as the page the
     visitor just left: the new active label wears the inactive look here
     (the pill is not under it yet — text-bar on the bare bar would be
     invisible), and the previous slot's link wears the active look via a
     rule lang-pill-slide.js injects (only the script knows the slot). */
  html.lang-pill-slide .language-switcher-active {
    transform: translateX(calc(var(--lang-pill-from) * 100%));
  }

  html.lang-pill-slide .language-switcher-desktop [aria-current] {
    color: color-mix(in oklab, var(--color-bar-fg) 60%, transparent);
  }
</style>

<script>
  import { initLangDropdown } from '../../scripts/lang-dropdown';
  import { initLangPillFlag } from '../../scripts/lang-pill';
  initLangDropdown();
  initLangPillFlag();
</script>
