---
import Icon from '../Icon.astro';
import { Languages, useTranslations, getLangFromUrl } from '../../i18n/translations';
import type { LangLink } from './LanguageSwitcherDesktop.astro';
import globeSvg from '../../assets/icons/globe.svg?raw';

interface Props {
  currentLang: Languages;
  langLinks: LangLink[];
}

const { currentLang, langLinks } = Astro.props;
const t = useTranslations(getLangFromUrl(Astro.url));
---

<div class="relative md:hidden">
  <button
    id="lang-dropdown-toggle"
    class="relative flex items-center justify-center w-11 h-11 text-bar-fg cursor-pointer hover:bg-white/10 transition-colors rounded-md"
    aria-expanded="false"
    aria-label={t('a11y:select-language')}
  >
    <!-- Globe icon + active-lang badge -->
    <span class="relative" aria-hidden="true">
      <Icon svg={globeSvg} size="md" />
      <span class="lang-badge absolute -bottom-0.5 -right-1 text-[7px] font-bold leading-none bg-bar-fg text-bar rounded px-[3px] py-[2px]">
        {currentLang.toUpperCase()}
      </span>
    </span>
  </button>

  <div
    id="lang-dropdown"
    class="hidden absolute right-0 top-full mt-1 min-w-[4rem] rounded-md bg-bar border border-white/20 overflow-hidden shadow-lg"
    role="menu"
  >
    {langLinks.map((link) => {
      const isActive = link.href === null;
      return isActive ? (
        <span
          class="block px-4 py-2 text-sm font-medium text-bar-fg bg-white/10"
          role="menuitem"
          aria-current="true"
        >
          {link.label}
        </span>
      ) : (
        <a
          href={link.href}
          rel="alternate"
          hreflang={link.lang}
          class="block px-4 py-2 text-sm font-medium text-bar-fg/60 hover:bg-white/10 hover:text-bar-fg transition-colors"
          role="menuitem"
        >
          {link.label}
        </a>
      );
    })}
  </div>
</div>

<script>
  // Close dropdown on outside click (one-time global listener).
  document.addEventListener('click', () => {
    const dropdown = document.getElementById('lang-dropdown');
    const toggle = document.getElementById('lang-dropdown-toggle');
    if (!dropdown?.classList.contains('hidden')) {
      dropdown?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });

  // Re-bind toggle on every navigation — ClientRouter swaps the DOM.
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('lang-dropdown-toggle');
    const dropdown = document.getElementById('lang-dropdown');

    toggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = dropdown?.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  });
</script>

