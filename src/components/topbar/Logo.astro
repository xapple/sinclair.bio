---
import { Languages } from '../../i18n/translations';
import logoSvg from '../../assets/logo.svg?raw';

interface Props {
  lang?: Languages;
}

const { lang = Languages.en } = Astro.props;
---

<a href={`/${lang}/`} class="flex items-center gap-2 text-bar-fg" aria-label="Home">
  <span class="logo-mark" aria-hidden="true"><Fragment set:html={logoSvg} /></span>
  <span class="rounded-2xl border-2 border-bar-fg/70 px-4 py-1.5 text-xl font-bold tracking-tight leading-none">
    Sinclair.Bio
  </span>
</a>

