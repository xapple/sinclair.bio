---
import { usePageFromUrl } from '../../i18n/page';
import logoNameSvg from '../../assets/logo-name.svg?raw';

const { lang, t } = usePageFromUrl(Astro.url);
---

<a href={`/${lang}/`} class="flex items-center text-bar-fg" aria-label={t('a11y:home')}>
  <span class="logo-name" style="display:block;height:2rem;width:auto" aria-hidden="true"><Fragment set:html={logoNameSvg} /></span>
</a>

