---
import { Languages } from '../../i18n/translations';
import logoNameSvg from '../../assets/logo-name.svg?raw';

interface Props {
  lang?: Languages;
}

const { lang = Languages.en } = Astro.props;
---

<a href={`/${lang}/`} class="flex items-center text-bar-fg" aria-label="Home">
  <span class="logo-name" style="display:block;height:2rem;width:auto" aria-hidden="true"><Fragment set:html={logoNameSvg} /></span>
</a>

