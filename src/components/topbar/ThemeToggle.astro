---
import Icon from '../Icon.astro';
import themeSwitcherSvg from '../../assets/theme-switcher.svg?raw';
import sunSvg from '../../assets/icons/sun.svg?raw';
import moonSvg from '../../assets/icons/moon-stars.svg?raw';

const { t } = Astro.locals;
---

<script>
  import { initThemeToggles, setTheme } from "../../scripts/theme-switcher";

  window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
    setTheme(e.matches ? "dark" : "light");
  });

  initThemeToggles();
</script>

<!-- Full pill toggle — desktop only -->
<button
  title={t("a11y:theme-switcher")}
  class="theme-switcher relative hidden md:flex items-center self-center p-0 border-none bg-transparent cursor-pointer"
  aria-label={t("a11y:theme-switcher")}
>
  <Fragment set:html={themeSwitcherSvg} />
</button>

<!-- Compact icon toggle — mobile only -->
<button
  title={t("a11y:theme-switcher")}
  class="compact-theme-toggle md:hidden flex items-center justify-center w-11 h-11 p-0 border-none bg-transparent cursor-pointer hover:bg-white/10 transition-colors rounded-md text-bar-fg"
  aria-label={t("a11y:theme-switcher")}
>
  <!-- Sun: shown in light mode -->
  <Icon svg={sunSvg} size="md" class="compact-sun" />
  <!-- Moon: shown in dark mode -->
  <Icon svg={moonSvg} size="md" class="compact-moon" />
</button>

<style is:global>
  .theme-switcher {
    height: 2.0rem;
    width: calc(2 * 1.6rem);
  }

  .theme-switcher svg {
    position: absolute;
    height: inherit;
    width: auto;
  }

  /* Track: always semi-transparent white — visible on the dark bar in both modes */
  .theme-switcher svg #theme-switcher-bg {
    fill: rgba(255, 255, 255, 0.18);
  }

  /* Knob + icons: always bar-fg — contrasts with the dark bar and semi-transparent track */
  .theme-switcher svg #theme-switcher-circle {
    fill: var(--color-bar-fg);
    color: var(--color-bar-fg);
  }

  .theme-switcher svg #theme-switcher-sun,
  .theme-switcher svg #theme-switcher-moon {
    color: var(--color-bar-fg);
  }

  /* Compact toggle: show sun in light mode, moon in dark mode.
     Icon sizing comes from .icon-md in global.css. */
  .compact-theme-toggle .compact-moon { display: none; }
  html[data-theme="dark"] .compact-theme-toggle .compact-sun  { display: none; }
  html[data-theme="dark"] .compact-theme-toggle .compact-moon { display: inline-flex; }
</style>
