---
import { useTranslations, getLangFromUrl } from '../../i18n/translations';
import themeSwitcherSvg from '../../assets/theme-switcher.svg?raw';

const t = useTranslations(getLangFromUrl(Astro.url));
---

<script>
  import { themeSwitcherManager } from "../../scripts/theme-switcher";
  // Astro module scripts are deferred, so DOMContentLoaded may have already fired.
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", themeSwitcherManager);
  } else {
    themeSwitcherManager();
  }
</script>

<button
  title={t("a11y:theme-switcher")}
  class="theme-switcher relative flex items-center self-center p-0 border-none bg-transparent cursor-pointer"
  aria-label="Theme switcher"
>
  <Fragment set:html={themeSwitcherSvg} />
</button>

<style is:global>
  .theme-switcher {
    height: 2.0rem;
    width: calc(2 * 1.6rem);
  }

  .theme-switcher svg {
    position: absolute;
    height: inherit;
    width: auto;
  }

  /* Track: always semi-transparent white — visible on the dark bar in both modes */
  .theme-switcher svg #theme-switcher-bg {
    fill: rgba(255, 255, 255, 0.18);
  }

  /* Knob + icons: always bar-fg — contrasts with the dark bar and semi-transparent track */
  .theme-switcher svg #theme-switcher-circle {
    fill: var(--color-bar-fg);
    color: var(--color-bar-fg);
  }

  .theme-switcher svg #theme-switcher-sun,
  .theme-switcher svg #theme-switcher-moon {
    color: var(--color-bar-fg);
  }
</style>