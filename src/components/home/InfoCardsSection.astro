---
import Icon from '../Icon.astro';
import InfoCard from '../InfoCard.astro';
import { SOCIAL_LINKS } from '../../data/profile';

const { t } = Astro.locals;
---

<section class="pb-12">
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-12 max-w-56 sm:max-w-none mx-auto">

    <InfoCard icon="map-pin" heading={t('home:card-location-heading')}>
      <div class="space-y-0.5">
        <a href="https://openstreetmap.org/node/2115451216#map=16/46.21269/6.14982" target="_blank" rel="noopener noreferrer" class="link-underline text-sm">Rue Rothschild 35</a>
        <p class="text-sm text-ink">{t('home:location-city')}</p>
        <p class="text-sm text-ink flex items-center gap-1">{t('home:location-country')} <span>🇨🇭</span></p>
      </div>
    </InfoCard>

    <InfoCard icon="message-square" heading={t('home:card-languages-heading')}>
      <div class="space-y-0.5">
        <p class="text-sm text-ink">{t('home:language-english')}</p>
        <p class="text-sm text-ink">{t('home:language-french')}</p>
        <p class="text-sm text-ink">{t('home:language-others')}</p>
      </div>
    </InfoCard>

    <InfoCard icon="external-link" heading={t('home:card-links-heading')}>
      <div class="space-y-2">
        {SOCIAL_LINKS.map(({ icon, label, href }) => (
          <a href={href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-ink hover:text-accent transition-colors">
            <Icon name={icon} size="sm" />
            {label}
          </a>
        ))}
      </div>
    </InfoCard>

  </div>
</section>
