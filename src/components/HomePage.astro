---
import { Image } from 'astro:assets';
import { useTranslations, Languages } from '../i18n/translations';

import profile from '../assets/profile.jpg';
import mapPin       from '../assets/icons/map-pin.svg?raw';
import msgSquare    from '../assets/icons/message-square.svg?raw';
import extLink      from '../assets/icons/external-link.svg?raw';
import lockIcon     from '../assets/icons/lock.svg?raw';
import githubIcon   from '../assets/icons/github.svg?raw';
import gitlabIcon   from '../assets/icons/gitlab.svg?raw';
import linkedinIcon from '../assets/icons/linkedin.svg?raw';
import telegramIcon from '../assets/icons/telegram.svg?raw';
import signalIcon   from '../assets/icons/signal.svg?raw';
import threemaIcon  from '../assets/icons/threema.svg?raw';
import matrixIcon   from '../assets/icons/matrix.svg?raw';
import messagesSquareIcon from '../assets/icons/messages-square.svg?raw';

interface Props {
  lang?: Languages;
}

const { lang = Languages.en } = Astro.props;
const t = useTranslations(lang);
---

<!-- Hero -->
<section class="home-reveal mx-auto max-w-3xl px-6 pt-16 pb-10" style="--delay:0ms">
  <div class="flex flex-col sm:flex-row items-center sm:items-center gap-6 text-center sm:text-left">
    <Image
      src={profile}
      format="webp"
      widths={[128, 256]}
      sizes="128px"
      alt="Lucas Sinclair"
      class="block h-32 w-auto rounded-xl shrink-0 border border-ink"
    />
    <div>
      <p class="text-2xl leading-snug">{t('home:greeting')}</p>
      <h1 class="text-4xl font-black text-ink leading-tight">{t('home:name')}</h1>
      <p class="mt-1.5 text-base text-muted">{t('home:tagline')}</p>
    </div>
  </div>
</section>

<!-- Info cards -->
<section class="home-reveal mx-auto max-w-3xl px-6 pb-12" style="--delay:80ms">
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-12">

    <!-- Location -->
    <div class="rounded-xl bg-surface border border-border overflow-hidden">
      <div class="bg-border/50 px-5 py-3">
        <h3 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-muted">
          <span class="icon-sm" aria-hidden="true" set:html={mapPin} />
          {t('home:card-location-heading')}
        </h3>
      </div>
      <div class="px-5 py-4 space-y-0.5">
        <a href="https://www.openstreetmap.org/node/2115451216#map=16/46.21269/6.14982" target="_blank" rel="noopener noreferrer" class="text-sm text-ink hover:text-accent transition-colors underline underline-offset-2">Rue Rothschild 35</a>
        <p class="text-sm text-ink">{t('home:location-city')}</p>
        <p class="text-sm text-ink flex items-center gap-1">{t('home:location-country')} <span>🇨🇭</span></p>
      </div>
    </div>

    <!-- Languages -->
    <div class="rounded-xl bg-surface border border-border overflow-hidden">
      <div class="bg-border/50 px-5 py-3">
        <h3 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-muted">
          <span class="icon-sm" aria-hidden="true" set:html={msgSquare} />
          {t('home:card-languages-heading')}
        </h3>
      </div>
      <div class="px-5 py-4 space-y-0.5">
        <p class="text-sm text-ink">{t('home:language-english')}</p>
        <p class="text-sm text-ink">{t('home:language-french')}</p>
        <p class="text-sm text-ink">{t('home:language-others')}</p>
      </div>
    </div>

    <!-- Links -->
    <div class="rounded-xl bg-surface border border-border overflow-hidden">
      <div class="bg-border/50 px-5 py-3">
        <h3 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-muted">
          <span class="icon-sm" aria-hidden="true" set:html={extLink} />
          {t('home:card-links-heading')}
        </h3>
      </div>
      <div class="px-5 py-4 space-y-2">
        <a href="https://github.com/xapple" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-ink hover:text-accent transition-colors">
          <span class="icon-sm" aria-hidden="true" set:html={githubIcon} />
          github/xapple
        </a>
        <a href="https://gitlab.com/sinclair" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-ink hover:text-accent transition-colors">
          <span class="icon-sm" aria-hidden="true" set:html={gitlabIcon} />
          gitlab/sinclair
        </a>
        <a href="https://linkedin.com/in/sinclair-bio" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-ink hover:text-accent transition-colors">
          <span class="icon-sm" aria-hidden="true" set:html={linkedinIcon} />
          in/sinclair-bio
        </a>
      </div>
    </div>

  </div>
</section>

<!-- About -->
<section class="home-reveal mx-auto max-w-3xl px-6 py-12" style="--delay:200ms">
  <h2 class="mb-6 text-xs font-semibold uppercase tracking-widest text-accent">
    {t('home:about-heading')}
  </h2>
  <div class="space-y-4 text-base leading-relaxed text-ink">
    <p>{t('home:about-p1')}</p>
    <p>{t('home:about-p2')}</p>
    <p>{t('home:about-p3')}</p>
    <p>{t('home:about-p4')}</p>
    <p>{t('home:about-p5')}</p>
  </div>
</section>

<!-- Get in Touch -->
<section class="home-reveal mx-auto max-w-3xl px-6 py-12" style="--delay:340ms">
  <h2 class="mb-8 text-xs font-semibold uppercase tracking-widest text-accent">
    {t('home:contact-heading')}
  </h2>
  <div class="flex flex-col md:flex-row items-start gap-6 md:gap-8">

    <!-- Form -->
    <form
      id="form"
      class="flex-1 flex flex-col gap-3 w-full"
      data-sending={t('home:contact-sending')}
      data-sent={t('home:contact-sent')}
      data-error={t('home:contact-error')}
      data-error-generic={t('home:contact-error-generic')}
    >
      <input
        type="text"
        name="name"
        placeholder={t('home:contact-name')}
        aria-label={t('home:contact-name')}
        autocomplete="name"
        required
        class="w-full rounded-lg border border-border bg-back px-4 py-2.5 text-sm text-ink placeholder:text-muted focus:border-accent focus:outline-none transition-colors"
      />
      <input
        type="email"
        name="email"
        placeholder={t('home:contact-email')}
        aria-label={t('home:contact-email')}
        autocomplete="email"
        required
        class="w-full rounded-lg border border-border bg-back px-4 py-2.5 text-sm text-ink placeholder:text-muted focus:border-accent focus:outline-none transition-colors"
      />
      <textarea
        name="message"
        placeholder={t('home:contact-message')}
        aria-label={t('home:contact-message')}
        rows={5}
        required
        class="w-full rounded-lg border border-border bg-back px-4 py-2.5 text-sm text-ink placeholder:text-muted focus:border-accent focus:outline-none transition-colors resize-none"
      ></textarea>
      <div class="flex items-center gap-3">
        <button
          type="submit"
          class="rounded-lg bg-ink px-6 py-2.5 text-sm font-semibold text-back hover:bg-accent transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
        >
          {t('home:contact-send')}
        </button>
        <span id="contact-status" class="text-sm"></span>
      </div>
    </form>

    <!-- OR divider -->
    <div class="flex md:flex-col items-center self-center gap-2 md:gap-3 text-muted/40">
      <div class="flex-1 h-px md:h-12 w-full md:w-px bg-border"></div>
      <span class="text-xl font-bold">{t('home:contact-divider')}</span>
      <div class="flex-1 h-px md:h-12 w-full md:w-px bg-border"></div>
    </div>

    <!-- Right column: DM + Meeting -->
    <div class="w-full md:w-56 flex flex-col gap-4">

      <!-- Private note -->
      <div class="rounded-xl bg-surface border border-border overflow-hidden">
        <div class="bg-border/50 px-5 py-3">
          <h3 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-muted">
            <span class="icon-sm" aria-hidden="true" set:html={lockIcon} />
            <span>{t('home:dm-heading')}</span>
          </h3>
        </div>
        <ul class="space-y-3 text-sm px-5 py-4">
          <li class="flex items-center justify-between gap-2">
            <span class="flex items-center gap-1.5 text-muted shrink-0">
              <span class="icon-xs" aria-hidden="true" set:html={telegramIcon} />
              Telegram:
            </span>
            <a href="https://t.me/sinclair99" target="_blank" rel="noopener noreferrer" class="text-ink hover:text-accent transition-colors truncate underline underline-offset-2">@sinclair99</a>
          </li>
          <li class="flex items-center justify-between gap-2">
            <span class="flex items-center gap-1.5 text-muted shrink-0">
              <span class="icon-xs" aria-hidden="true" set:html={signalIcon} />
              Signal:
            </span>
            <a href="https://signal.me/#eu/R-vlT2way2bjfP_7a4OIQhF-kmpZYAB3M24x-b0ue15FoM4CvZNEjKD0qfCVNF5_" target="_blank" rel="noopener noreferrer" class="text-ink hover:text-accent transition-colors truncate underline underline-offset-2">@sinclair.99</a>
          </li>
          <li class="flex items-center justify-between gap-2">
            <span class="flex items-center gap-1.5 text-muted shrink-0">
              <span class="icon-xs" aria-hidden="true" set:html={threemaIcon} />
              Threema:
            </span>
            <a href="https://threema.id/p3wmfn9c" target="_blank" rel="noopener noreferrer" class="text-ink hover:text-accent transition-colors truncate underline underline-offset-2">@p3wmfn9c</a>
          </li>
          <li class="flex items-center justify-between gap-2">
            <span class="flex items-center gap-1.5 text-muted shrink-0">
              <span class="icon-xs" aria-hidden="true" set:html={matrixIcon} />
              Matrix:
            </span>
            <a href="https://matrix.to/#/@sinclair.bio:matrix.org" target="_blank" rel="noopener noreferrer" class="text-ink hover:text-accent transition-colors truncate underline underline-offset-2">@sinclair.bio</a>
          </li>
        </ul>
      </div>

      <!-- Short Meeting -->
      <a
        href={`/${lang}/talk`}
        class="block rounded-xl bg-surface border border-border overflow-hidden hover:border-accent transition-colors group"
      >
        <div class="bg-border/50 px-5 py-3">
          <h3 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-muted">
            <span class="icon-sm" aria-hidden="true" set:html={messagesSquareIcon} />
            <span>{t('home:meeting-heading')}</span>
          </h3>
        </div>
        <div class="px-5 py-4">
          <p class="text-sm text-ink group-hover:text-accent transition-colors underline underline-offset-2">{t('home:meeting-body')}</p>
        </div>
      </a>

    </div>

  </div>
</section>

<script>
  // Re-bind on every navigation — ClientRouter swaps the DOM, so listeners
  // attached to a previous instance of the form are lost on SPA nav.
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('form') as HTMLFormElement | null;
    if (!form) return;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const status = document.getElementById('contact-status') as HTMLSpanElement;
    const { sending, sent, error, errorGeneric } = form.dataset;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      formData.append('access_key', 'cb34a33c-14b3-4b35-b978-25080a102993');

      const originalText = submitBtn.textContent;
      submitBtn.textContent = sending!;
      submitBtn.disabled = true;

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (response.ok) {
          status.textContent = sent!;
          status.className = 'text-sm text-green-600 dark:text-green-400';
          form.reset();
        } else {
          status.textContent = error!.replace('%s', data.message);
          status.className = 'text-sm text-red-500';
        }
      } catch (err) {
        status.textContent = errorGeneric!;
        status.className = 'text-sm text-red-500';
      } finally {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    });
  });
</script>

<style>
  /* Icon wrappers — control size; SVG inherits currentColor from parent */
  .icon-sm {
    display: inline-flex;
    width:  1rem;
    height: 1rem;
    flex-shrink: 0;
  }
  .icon-xs {
    display: inline-flex;
    width:  0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
  }
  .icon-sm > svg,
  .icon-xs > svg {
    width: 100%;
    height: 100%;
  }

  .home-reveal {
    opacity: 0;
    transform: translateY(12px);
    animation: home-reveal 500ms ease-out both;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes home-reveal {
    to { opacity: 1; transform: translateY(0); }
  }
</style>
