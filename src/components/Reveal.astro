---
// Fade-up entrance wrapper. Uses the `.page-reveal` keyframe in global.css.
// Timing/stagger is owned by reveal-on-scroll.js (each element animates as it
// scrolls into view), so there's no per-element delay knob — pass `duration`
// to tune fade speed, `as` to swap the wrapper tag.
interface Props {
  duration?: number;    // ms — omit to inherit the .page-reveal default
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const { duration, as: Tag = 'div', class: extraClass } = Astro.props;
const style = duration !== undefined ? `--reveal-duration:${duration}ms` : undefined;
---

<Tag class:list={['page-reveal', extraClass]} style={style}>
  <slot />
</Tag>
