---
// Fade-up entrance wrapper. Uses the `.page-reveal` keyframe in global.css —
// pass `delay`/`duration` to tune timing, `as` to swap the wrapper tag.
interface Props {
  delay?: number;       // ms
  duration?: number;    // ms — omit to inherit the .page-reveal default
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const { delay = 0, duration, as: Tag = 'div', class: extraClass } = Astro.props;
const parts: string[] = [];
if (delay) parts.push(`--reveal-delay:${delay}ms`);
if (duration !== undefined) parts.push(`--reveal-duration:${duration}ms`);
const style = parts.length ? parts.join('; ') : undefined;
---

<Tag class:list={['page-reveal', extraClass]} style={style}>
  <slot />
</Tag>
