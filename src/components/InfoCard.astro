---
import Icon from './Icon.astro';

interface Props {
  icon: string;     // raw SVG markup (use `?raw` import)
  heading: string;
  href?: string;    // if set, the whole card is a hover-accent link
}

const { icon, heading, href } = Astro.props;

const baseClass = 'rounded-xl bg-surface border border-border overflow-hidden';
const linkClass = href ? ' block hover:border-accent transition-colors group' : '';
const Wrapper = href ? 'a' : 'div';
---

<Wrapper class={`${baseClass}${linkClass}`} href={href}>
  <div class="bg-border/50 px-5 py-3">
    <h3 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-muted">
      <Icon svg={icon} size="sm" />
      <span>{heading}</span>
    </h3>
  </div>
  <div class="px-5 py-4">
    <slot />
  </div>
</Wrapper>
