---
const cellSize = 32;
const width    = 600;
const height   = 400;

const vPositions = Array.from({ length: Math.floor(width  / cellSize) + 1 }, (_, i) => i * cellSize);
const hPositions = Array.from({ length: Math.floor(height / cellSize) + 1 }, (_, i) => i * cellSize);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={width}
  height={height}
  viewBox={`0 0 ${width} ${height}`}
  aria-hidden="true"
  class="grid-decoration"
>
  <defs>
    {vPositions.map((x, i) => (
      <linearGradient id={`gd-v${i}`} gradientUnits="userSpaceOnUse" x1="0" y1="0" x2="0" y2={height}>
        <stop offset="0%"   style={`stop-color:var(--color-border);stop-opacity:${(x / width).toFixed(4)}`} />
        <stop offset="100%" style="stop-color:var(--color-border);stop-opacity:0" />
      </linearGradient>
    ))}
    {hPositions.map((y, j) => (
      <linearGradient id={`gd-h${j}`} gradientUnits="userSpaceOnUse" x1="0" y1="0" x2={width} y2="0">
        <stop offset="0%"   style="stop-color:var(--color-border);stop-opacity:0" />
        <stop offset="100%" style={`stop-color:var(--color-border);stop-opacity:${((height - y) / height).toFixed(4)}`} />
      </linearGradient>
    ))}
  </defs>
  <g shape-rendering="crispEdges">
    {vPositions.map((x, i) => (
      <line x1={x} y1="0" x2={x} y2={height} stroke={`url(#gd-v${i})`} stroke-width="1" />
    ))}
    {hPositions.map((y, j) => (
      <line x1="0" y1={y} x2={width} y2={y} stroke={`url(#gd-h${j})`} stroke-width="1" />
    ))}
  </g>
</svg>

<style>
  .grid-decoration {
    position: absolute;
    top: 0;
    right: 0;
    pointer-events: none;
    user-select: none;
  }
</style>
