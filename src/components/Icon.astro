---
import { getIcon } from '../assets/icons';

interface Props {
  name: string;                                 // basename of a file in src/assets/icons/
  size?: 'xs' | 'sm' | 'md' | 'lg';             // semantic size → .icon-{size} class
  label?: string;                               // if set, span becomes role="img" with this aria-label
  id?: string;                                  // for JS-toggleable icons
  class?: string;                               // extra classes (layout, color, responsive overrides)
}

const { name, size = 'sm', label, id, class: extraClass } = Astro.props;
const svg = getIcon(name);

const aria = label
  ? { role: 'img' as const, 'aria-label': label }
  : { 'aria-hidden': 'true' as const };
---

<span id={id} class:list={['icon', `icon-${size}`, extraClass]} {...aria} set:html={svg} />
