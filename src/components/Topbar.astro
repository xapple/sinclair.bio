---
import Logo from './topbar/Logo.astro';
import NavLinks from './topbar/NavLinks.astro';
import ThemeToggle from './topbar/ThemeToggle.astro';
import LanguageSwitcher from './topbar/LanguageSwitcher.astro';
import Icon from './Icon.astro';
import { useTranslations, getLangFromUrl } from '../i18n/translations';
import squareMenuSvg from '../assets/icons/square-menu.svg?raw';
import squareXSvg from '../assets/icons/square-x.svg?raw';
import personCircleSvg from '../assets/icons/person-circle.svg?raw';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="sticky top-0 z-50 w-full bg-bar">
  <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Left: Logo -->
    <div class="flex shrink-0 items-center">
      <Logo />
    </div>

    <!-- Center: Nav links (hidden on mobile) -->
    <div class="hidden md:flex md:items-center md:gap-1">
      <NavLinks />
    </div>

    <!-- Right: Widgets + Hamburger -->
    <div class="flex items-center gap-3 md:gap-6">
      <div class="flex items-center"><LanguageSwitcher /></div>
      <div class="flex items-center"><ThemeToggle /></div>

      <!-- Login button -->
      <a
        href={`/${lang}/login`}
        class="inline-flex items-center justify-center w-11 h-11 md:ml-2 text-bar-fg cursor-pointer hover:bg-white/10 transition-colors rounded-md"
        aria-label={t('a11y:login')}
      >
        <Icon svg={personCircleSvg} size="md" class="md:w-8 md:h-8" />
      </a>

      <!-- Hamburger (mobile only). One icon, SVG swapped on click — avoids
           any window where both icons could paint. Menu starts open, so the
           close (X) glyph is the initial render. -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="inline-flex items-center justify-center w-11 h-11 text-bar-fg cursor-pointer hover:bg-white/10 transition-colors rounded-md md:hidden"
        aria-expanded="true"
        aria-label={t('a11y:toggle-menu')}
      >
        <Icon id="mobile-menu-icon" svg={squareXSvg} size="md" />
      </button>
    </div>
  </nav>

  <!-- Mobile menu (open by default, dismissible via hamburger).
       Open/close animation lives in global.css under #mobile-menu. -->
  <div id="mobile-menu" class="mobile-menu border-t border-white/10 md:hidden">
    <div class="flex justify-center gap-1 px-2 py-2">
      <NavLinks />
    </div>
  </div>
</header>

<script define:vars={{ squareMenuSvg, squareXSvg }}>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('mobile-menu-icon');

  // Measure the menu's natural height. Briefly drop maxHeight so scrollHeight
  // reads the unconstrained content even mid-animation.
  const naturalHeight = () => {
    if (!menu) return 0;
    const prev = menu.style.maxHeight;
    menu.style.maxHeight = 'none';
    const h = menu.scrollHeight;
    menu.style.maxHeight = prev;
    return h;
  };

  // Initial open state: pin maxHeight to the measured natural height so the
  // first close has a concrete value to animate from.
  if (menu) menu.style.maxHeight = naturalHeight() + 'px';

  toggle?.addEventListener('click', () => {
    if (!menu) return;
    const isClosed = menu.toggleAttribute('data-closed');
    const isOpen = !isClosed;
    // Re-measure each open in case viewport/font changed.
    menu.style.maxHeight = isClosed ? '0px' : naturalHeight() + 'px';
    if (icon) icon.innerHTML = isOpen ? squareXSvg : squareMenuSvg;
    toggle.setAttribute('aria-expanded', String(isOpen));
  });
</script>
