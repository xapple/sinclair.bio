---
import Logo from './topbar/Logo.astro';
import NavLinks from './topbar/NavLinks.astro';
import ThemeToggle from './topbar/ThemeToggle.astro';
import LanguageSwitcher from './topbar/LanguageSwitcher.astro';
import { Languages, useTranslations } from '../i18n/translations';
import squareMenuSvg from '../assets/icons/square-menu.svg?raw';
import squareXSvg from '../assets/icons/square-x.svg?raw';
import personCircleSvg from '../assets/icons/person-circle.svg?raw';

interface Props {
  lang?: Languages;
}

const { lang = Languages.en } = Astro.props;
const t = useTranslations(lang);
---

<header class="sticky top-0 z-50 w-full bg-bar">
  <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Left: Logo -->
    <div class="flex shrink-0 items-center">
      <Logo lang={lang} />
    </div>

    <!-- Center: Nav links (hidden on mobile) -->
    <div class="hidden md:flex md:items-center md:gap-1">
      <NavLinks lang={lang} />
    </div>

    <!-- Right: Widgets + Hamburger -->
    <div class="flex items-center gap-3 md:gap-6">
      <div class="flex items-center"><LanguageSwitcher lang={lang} /></div>
      <div class="flex items-center"><ThemeToggle /></div>

      <!-- Login button -->
      <a
        href={`/${lang}/login`}
        class="inline-flex items-center justify-center w-11 h-11 md:ml-2 text-bar-fg cursor-pointer hover:bg-white/10 transition-colors rounded-md"
        aria-label={t('a11y:login')}
      >
        <span class="w-6 h-6 md:w-8 md:h-8" aria-hidden="true"><Fragment set:html={personCircleSvg} /></span>
      </a>

      <!-- Hamburger (mobile only) -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="inline-flex items-center justify-center w-11 h-11 text-bar-fg cursor-pointer hover:bg-white/10 transition-colors rounded-md md:hidden"
        aria-expanded="true"
        aria-label={t('a11y:toggle-menu')}
      >
        <span id="hamburger-icon" class="hidden h-6 w-6" aria-hidden="true"><Fragment set:html={squareMenuSvg} /></span>
        <span id="close-icon" class="h-6 w-6" aria-hidden="true"><Fragment set:html={squareXSvg} /></span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu (open by default, dismissible via hamburger) -->
  <div id="mobile-menu" class="border-t border-white/10 md:hidden">
    <div class="flex justify-center gap-1 px-2 py-2">
      <NavLinks lang={lang} />
    </div>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');

    toggle?.addEventListener('click', () => {
      const isOpen = menu?.classList.toggle('hidden') === false;
      hamburgerIcon?.classList.toggle('hidden', isOpen);
      closeIcon?.classList.toggle('hidden', !isOpen);
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  });
</script>
