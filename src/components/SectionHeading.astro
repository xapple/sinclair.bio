---
import Icon from './Icon.astro';

interface Props {
  icon: string;
  text: string;
  id?: string;
  // Reveal the heading on scroll itself (adds .page-reveal) instead of needing a
  // wrapper <Reveal> just to fade a heading in. Follows global.css's rule: put
  // the class directly on elements that carry their own tag.
  reveal?: boolean;
}

const { icon, text, id, reveal } = Astro.props;
---

<h2 class:list={['section-heading', reveal && 'page-reveal']} id={id}>
  <Icon name={icon} />
  <span>{text}</span>
</h2>
