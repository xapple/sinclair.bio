---
interface Props {
  title: string;
  titleHref?: string;
  // Primary accent-coloured subtitle line (company / degree / issuer).
  subtitle: string;
  // Optional tertiary line under the subtitle.
  tertiary?: string;
  // 'eyebrow' = small uppercase letterspaced (experience's employmentType).
  // 'field'   = plain muted line (education/certs field).
  tertiaryStyle?: 'eyebrow' | 'field';
  period: string;
  location?: string;
  summary: string;
  bullets?: string[];
  // Panel column ratio. 'wide' = experiences (slightly wider body),
  // 'narrow' = education/certifications (more even split).
  variant?: 'wide' | 'narrow';
  // Zero-based position within its section — drives the stagger animation.
  index: number;
}

const {
  title,
  titleHref,
  subtitle,
  tertiary,
  tertiaryStyle = 'field',
  period,
  location,
  summary,
  bullets,
  variant = 'wide',
  index,
} = Astro.props;
---

<li class={`entry-item entry-item--${variant}`} style={`--item-index:${index};`}>
  <span class="entry-dot" aria-hidden="true"></span>
  <article class="entry-panel">
    <div class="entry-left">
      <div class="entry-meta">
        <p class="period-badge">{period}</p>
        {location && <p class="entry-location">{location}</p>}
      </div>

      <div class="entry-heading">
        <h3>
          {titleHref ? (
            <a href={titleHref} target="_blank" rel="noopener noreferrer">{title}</a>
          ) : (
            title
          )}
        </h3>
        <p class="primary-meta">{subtitle}</p>
        {tertiary && (
          <p class={tertiaryStyle === 'eyebrow' ? 'secondary-meta' : 'field-meta'}>{tertiary}</p>
        )}
      </div>
    </div>

    <div class="entry-body">
      <p class="summary">{summary}</p>
      {bullets && bullets.length > 0 && (
        <ul class="detail-list">
          {bullets.map((b) => <li>{b}</li>)}
        </ul>
      )}
    </div>
  </article>
</li>

<style>
  .entry-item {
    position: relative;
    padding: 0 0 0 var(--entry-inner-pad);
    margin-bottom: var(--entry-gap);
    opacity: 0;
    transform: translateY(14px);
    animation: reveal 560ms ease-out forwards;
    animation-delay: calc((var(--section-base, 0) + var(--item-index) + 1) * 90ms);
  }

  .entry-item:last-child {
    margin-bottom: 0;
  }

  .entry-item::before {
    content: '';
    position: absolute;
    left: calc(var(--timeline-axis) - var(--entry-indent));
    top: 0;
    bottom: calc(-1 * var(--entry-gap));
    width: 2px;
    background: color-mix(in srgb, var(--color-border) 88%, transparent);
    transform: translateX(-50%);
  }

  .entry-item:first-child::before {
    top: 50%;
  }

  .entry-item:last-child::before {
    bottom: 50%;
  }

  .entry-dot {
    position: absolute;
    left: calc(var(--timeline-axis) - var(--entry-indent));
    top: 50%;
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--color-accent) 12%, transparent);
    transform: translate(-50%, -50%);
  }

  .entry-panel {
    border: 1px solid color-mix(in srgb, var(--color-border) 78%, transparent);
    border-radius: 1.2rem;
    padding: clamp(1rem, 2.4vw, 1.4rem);
    background: color-mix(in srgb, var(--color-bkgnd) 84%, var(--color-surface) 16%);
    backdrop-filter: blur(8px);
    display: grid;
    gap: clamp(1rem, 3vw, 2rem);
    align-items: start;
  }

  .entry-item--wide   .entry-panel { grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.35fr); }
  .entry-item--narrow .entry-panel { grid-template-columns: minmax(0, 1fr)    minmax(0, 1.15fr); }

  .entry-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 0.9rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .period-badge {
    margin: 0;
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.32rem 0.8rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .entry-location {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.87rem;
    line-height: 1.4;
  }

  .entry-heading h3 {
    margin: 0;
    color: var(--color-ink);
    font-size: clamp(1rem, 1.5vw, 1.26rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 800;
  }

  .entry-heading h3 a {
    color: inherit;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 55%, transparent);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .entry-heading h3 a:hover,
  .entry-heading h3 a:focus-visible {
    color: var(--color-accent);
  }

  .primary-meta {
    margin: 0.55rem 0 0;
    color: var(--color-accent);
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .field-meta {
    margin: 0.2rem 0 0;
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .secondary-meta {
    margin: 0.45rem 0 0;
    color: var(--color-muted);
    font-size: 0.77rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .summary {
    margin: 0;
    color: var(--color-ink);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .detail-list {
    margin: 0.95rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.65rem;
  }

  .detail-list li {
    position: relative;
    padding-left: 1rem;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .detail-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62rem;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-accent) 68%, var(--color-border) 32%);
  }

  @media (max-width: 820px) {
    /* Match variant selectors' specificity so they don't override the collapse. */
    .entry-item--wide .entry-panel,
    .entry-item--narrow .entry-panel {
      grid-template-columns: 1fr;
      gap: 0.9rem;
    }
  }

  @media (max-width: 700px) {
    .entry-dot,
    .entry-item::before {
      display: none;
    }
  }
</style>
