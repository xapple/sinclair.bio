---
import Icon from './Icon.astro';
import { useTranslations, Languages } from '../i18n/translations';

import botIcon from '../assets/icons/bot.svg?raw';
import heartIcon from '../assets/icons/heart.svg?raw';

interface Props {
  lang?: Languages;
}

const { lang = Languages.en } = Astro.props;
const t = useTranslations(lang);
---

<footer class="bg-bar">
  <div class="mx-auto flex max-w-3xl flex-col items-center justify-between gap-3 px-6 py-6 text-xs text-bar-fg/70 sm:flex-row">
    <span>{t('footer:copyright', new Date().getFullYear().toString())}</span>
    <span class="flex items-center gap-2">
      {t('footer:made-with')}
      <Icon svg={botIcon} size="sm" label={t('a11y:ai')} />
      <span aria-hidden="true">+</span>
      <Icon svg={heartIcon} size="sm" label={t('a11y:love')} />
    </span>
  </div>
</footer>
