---
// Stat-style "h-index N →" callout, rendered just above the ORCID callout in
// the Publications section. Shares the external-link chrome (icon, muted→ink
// hover, nudging arrow) with ExternalLinkCallout, but emphasises the metric
// value so it reads as a stat. Links to the source page that shows the number.
import { getIcon } from '../assets/icons';

interface Props {
  label: string;          // e.g. "h-index"
  value: string | number; // e.g. 10
  href: string;           // page that displays the metric (Scopus)
  icon?: string;          // basename in src/assets/icons/
}

const { label, value, href, icon = 'scopus' } = Astro.props;
const svg = getIcon(icon);
---

<p class="hindex-wrap">
  <a
    class="hindex-link"
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`${label} ${value} — on Scopus`}
  >
    <span class="hindex-icon" aria-hidden="true" set:html={svg} />
    <span class="hindex-label">{label}</span>
    <span class="hindex-value">{value}</span>
    <span class="hindex-arrow" aria-hidden="true">→</span>
  </a>
</p>

<style>
  .hindex-wrap {
    margin: 0.5rem 0 0;
  }

  .hindex-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .hindex-icon {
    display: inline-flex;
    font-size: 1rem;
    line-height: 1;
  }

  .hindex-icon :global(svg) {
    display: block;
    width: 1em;
    height: 1em;
  }

  .hindex-value {
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--color-accent);
  }

  .hindex-arrow {
    transition: transform 0.15s ease;
  }

  .hindex-link:hover,
  .hindex-link:focus-visible {
    color: var(--color-ink);
  }

  .hindex-link:hover .hindex-arrow,
  .hindex-link:focus-visible .hindex-arrow {
    transform: translateX(2px);
  }
</style>
