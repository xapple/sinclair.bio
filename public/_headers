/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://app.cal.eu https://app.cal.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.web3forms.com https://app.cal.eu https://app.cal.com https://cal.com https://clients.sinclair.bio; frame-src https://app.cal.eu https://app.cal.com https://cal.com; form-action 'self' https://api.web3forms.com https://clients.sinclair.bio; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; upgrade-insecure-requests
  Strict-Transport-Security: max-age=31536000
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()

# Astro fingerprints these filenames by content hash, so a change yields a new
# filename -- safe to cache forever. (Only this dir; HTML and public/ assets
# keep stable names and stay on default caching.)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
